{
  "family_id": "gate-preparation",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "debug-redaction-plan/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "plan_digest",
        "domain": "pullwise:debug-redaction-plan:v1"
      },
      "x-pullwise-semantics": {
        "document_rules": ["debug_redaction_plan"],
        "contextual_helpers": []
      },
      "required": ["schema_id", "plan_id", "task_id", "policy_digest", "allowed_json_pointers", "rule_ids", "debug_input_refs", "plan_digest"],
      "properties": {
        "schema_id": { "const": "debug-redaction-plan/v1" },
        "plan_id": { "type": "string", "pattern": "^redactplan_[0-9a-f]{32}$" },
        "task_id": { "type": "string", "pattern": "^task_[0-9a-f]{32}$" },
        "policy_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "allowed_json_pointers": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096,
            "pattern": "^/"
          }
        },
        "rule_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
          }
        },
        "debug_input_refs": {
          "type": "array",
          "maxItems": 4096,
          "uniqueItems": true,
          "items": {
            "$ref": "content-ref/v1",
            "x-pullwise-content-schema-ids": ["execution-state-manifest/v1", "local-tool-receipt/v1", "observation/v1", "stable-error/v1"]
          }
        },
        "plan_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "publication-content-manifest/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "manifest_digest",
        "domain": "pullwise:publication-content-manifest:v1"
      },
      "x-pullwise-semantics": {
        "document_rules": ["publication_content_manifest"],
        "contextual_helpers": []
      },
      "required": ["schema_id", "manifest_id", "task_id", "secret_policy_digest", "redaction_policy_digest", "entries", "entry_count", "manifest_digest"],
      "properties": {
        "schema_id": { "const": "publication-content-manifest/v1" },
        "manifest_id": {
          "type": "string",
          "pattern": "^pubmanifest_[0-9a-f]{32}$"
        },
        "task_id": { "type": "string", "pattern": "^task_[0-9a-f]{32}$" },
        "secret_policy_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "redaction_policy_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4096,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["json_pointer", "content_kind", "source_ref", "inline_digest", "redaction_receipt"],
            "properties": {
              "json_pointer": {
                "type": "string",
                "minLength": 1,
                "maxLength": 4096,
                "pattern": "^/"
              },
              "content_kind": {
                "enum": ["artifact_bytes", "diagnostic_summary", "unstructured_string"]
              },
              "source_ref": {
                "oneOf": [
                  {
                    "$ref": "content-ref/v1",
                    "x-pullwise-content-schema-ids": [
                      "change-set/v1",
                      "completion-proposal/v1",
                      "observation/v1",
                      "source-content/v1",
                      "task-report/v1",
                      "task-request/v1",
                      "verification-attestation/v1",
                      "verifier-work-report/v1"
                    ]
                  },
                  { "type": "null" }
                ]
              },
              "inline_digest": {
                "type": ["string", "null"],
                "pattern": "^[0-9a-f]{64}$"
              },
              "redaction_receipt": {
                "type": "object",
                "additionalProperties": false,
                "required": ["policy_digest", "original_sha256", "redacted_sha256", "status", "receipt_digest"],
                "properties": {
                  "policy_digest": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{64}$"
                  },
                  "original_sha256": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{64}$"
                  },
                  "redacted_sha256": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{64}$"
                  },
                  "status": { "const": "passed" },
                  "receipt_digest": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{64}$"
                  }
                }
              }
            },
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "content_kind": { "const": "artifact_bytes" },
                  "source_ref": {
                    "$ref": "content-ref/v1",
                    "x-pullwise-content-schema-ids": [
                      "change-set/v1",
                      "completion-proposal/v1",
                      "observation/v1",
                      "source-content/v1",
                      "task-report/v1",
                      "task-request/v1",
                      "verification-attestation/v1",
                      "verifier-work-report/v1"
                    ]
                  },
                  "inline_digest": { "const": null }
                }
              },
              {
                "type": "object",
                "properties": {
                  "content_kind": {
                    "enum": ["diagnostic_summary", "unstructured_string"]
                  },
                  "source_ref": { "const": null },
                  "inline_digest": {
                    "type": "string",
                    "pattern": "^[0-9a-f]{64}$"
                  }
                }
              }
            ]
          }
        },
        "entry_count": { "type": "integer", "minimum": 1, "maximum": 4096 },
        "manifest_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "terminalization-fact/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "fact_digest",
        "domain": "pullwise:terminalization-fact:v1"
      },
      "x-pullwise-semantics": {
        "document_rules": ["terminalization_fact"],
        "contextual_helpers": ["verify_terminalization_fact_context"]
      },
      "required": ["schema_id", "fact_id", "task_id", "observed_task_version", "idempotency_key", "reason_code", "source", "evidence_refs", "observed_at", "fact_digest"],
      "properties": {
        "schema_id": { "const": "terminalization-fact/v1" },
        "fact_id": { "type": "string", "pattern": "^termfact_[0-9a-f]{32}$" },
        "task_id": { "type": "string", "pattern": "^task_[0-9a-f]{32}$" },
        "observed_task_version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "idempotency_key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[\\x20-\\x7e]+$"
        },
        "reason_code": {
          "enum": [
            "BUDGET_EXHAUSTED",
            "CAPABILITY_UNAVAILABLE",
            "DEADLINE_REACHED",
            "INTERACTION_UNAVAILABLE",
            "POLICY_INVARIANT_BROKEN",
            "PROTOCOL_FAILURE",
            "RUNTIME_FAILURE",
            "STORAGE_FAILURE"
          ]
        },
        "source": { "$ref": "actor/v1" },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "uniqueItems": true,
          "items": {
            "$ref": "content-ref/v1",
            "x-pullwise-content-schema-ids": [
              "budget-summary/v1",
              "effective-execution-policy/v1",
              "execution-state-manifest/v1",
              "local-tool-receipt/v1",
              "requirement-ledger/v1",
              "source-tree-manifest/v1",
              "stable-error/v1",
              "task-request/v1"
            ]
          }
        },
        "observed_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "fact_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  ],

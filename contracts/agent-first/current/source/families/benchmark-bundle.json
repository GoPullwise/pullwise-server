{
  "family_id": "benchmark-bundle",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "benchmark-bundle/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "bundle_digest",
        "domain": "pullwise:benchmark-bundle:v1"
      },
      "x-pullwise-semantics": {
        "document_rules": ["benchmark_bundle"],
        "contextual_helpers": []
      },
      "required": [
        "schema_id",
        "benchmark_id",
        "package",
        "candidate_digest",
        "benchmark_version",
        "control_plane_digest",
        "evaluation_runtime_digest",
        "task_inventory_digest",
        "oracle_rubric_digest",
        "environment_image_digest",
        "statistical_implementation_version",
        "seeds",
        "repeats_per_task",
        "known_gold_task_count",
        "unknown_families",
        "oracle_positive_finding_count",
        "core_cluster_ids",
        "cluster_coverage",
        "signer_role",
        "signer_id",
        "key_id",
        "signature_algorithm",
        "signature",
        "issued_at",
        "expires_at",
        "bundle_digest"
      ],
      "properties": {
        "schema_id": {"const": "benchmark-bundle/v1"},
        "benchmark_id": {
          "type": "string",
          "pattern": "^benchmark_[0-9a-f]{32}$"
        },
        "package": {"$ref": "current-package-ref/v1"},
        "candidate_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "benchmark_version": {
          "type": "string",
          "pattern": "^benchmark-[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "control_plane_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "evaluation_runtime_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "task_inventory_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "oracle_rubric_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "environment_image_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "statistical_implementation_version": {
          "const": "pullwise-release-statistics/v1"
        },
        "seeds": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 2147483647
          }
        },
        "repeats_per_task": {"const": 3},
        "known_gold_task_count": {
          "type": "integer",
          "minimum": 120,
          "maximum": 1000000
        },
        "unknown_families": {
          "type": "array",
          "minItems": 3,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["family_id", "task_count"],
            "properties": {
              "family_id": {
                "type": "string",
                "pattern": "^unknown_[a-z0-9_]{1,64}$"
              },
              "task_count": {
                "type": "integer",
                "minimum": 15,
                "maximum": 1000000
              }
            }
          }
        },
        "oracle_positive_finding_count": {
          "type": "integer",
          "minimum": 50,
          "maximum": 1000000
        },
        "core_cluster_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^cluster_[a-z0-9_]{1,64}$"
          }
        },
        "cluster_coverage": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "cluster_id",
              "real_fix_tasks",
              "bad_or_incomplete_patch_tasks",
              "fake_success_or_zero_test_tasks",
              "environment_or_capability_failure_tasks",
              "adversarial_input_tasks"
            ],
            "properties": {
              "cluster_id": {
                "type": "string",
                "pattern": "^cluster_[a-z0-9_]{1,64}$"
              },
              "real_fix_tasks": {
                "type": "integer",
                "minimum": 3,
                "maximum": 1000000
              },
              "bad_or_incomplete_patch_tasks": {
                "type": "integer",
                "minimum": 3,
                "maximum": 1000000
              },
              "fake_success_or_zero_test_tasks": {
                "type": "integer",
                "minimum": 3,
                "maximum": 1000000
              },
              "environment_or_capability_failure_tasks": {
                "type": "integer",
                "minimum": 3,
                "maximum": 1000000
              },
              "adversarial_input_tasks": {
                "type": "integer",
                "minimum": 3,
                "maximum": 1000000
              }
            }
          }
        },
        "signer_role": {"const": "benchmark_owner"},
        "signer_id": {
          "type": "string",
          "pattern": "^principal_[a-z0-9_]{1,64}$"
        },
        "key_id": {
          "type": "string",
          "pattern": "^key_[A-Za-z0-9_-]{1,96}$"
        },
        "signature_algorithm": {"const": "Ed25519"},
        "signature": {
          "type": "string",
          "minLength": 2,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9_-]+$"
        },
        "issued_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "expires_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "bundle_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  ],

{
  "family_id": "transport-abandonment",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "transport-abandonment-record/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "abandonment_digest",
        "domain": "pullwise:transport-abandonment-record:v1"
      },
      "x-pullwise-semantics": {
        "document_rules": ["transport_abandonment_record"],
        "contextual_helpers": []
      },
      "required": [
        "schema_id",
        "package",
        "abandonment_id",
        "task_id",
        "attempt_id",
        "session_id",
        "owner_id",
        "grant_id",
        "lease_id",
        "previous_task_version",
        "abandoned_task_version",
        "deletion_version",
        "owner_epoch",
        "native_epoch",
        "transport_epoch",
        "grant_digest",
        "superseded_authority_digest",
        "reason",
        "abandoned_at",
        "abandonment_digest"
      ],
      "properties": {
        "schema_id": {"const":"transport-abandonment-record/v1"},
        "package": {"$ref":"current-package-ref/v1"},
        "abandonment_id": {"type":"string","pattern":"^abandonment_[0-9a-f]{32}$"},
        "task_id": {"type":"string","pattern":"^task_[0-9a-f]{32}$"},
        "attempt_id": {"type":"string","pattern":"^attempt_[0-9a-f]{32}$"},
        "session_id": {"type":"string","pattern":"^sess_[0-9a-f]{32}$"},
        "owner_id": {"type":"string","pattern":"^owner_[0-9a-f]{32}$"},
        "grant_id": {"type":"string","pattern":"^grant_[0-9a-f]{32}$"},
        "lease_id": {"type":"string","pattern":"^lease_[0-9a-f]{32}$"},
        "previous_task_version": {"type":"integer","minimum":1,"maximum":9007199254740991},
        "abandoned_task_version": {"type":"integer","minimum":2,"maximum":9007199254740991},
        "deletion_version": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "owner_epoch": {"type":"integer","minimum":1,"maximum":9007199254740991},
        "native_epoch": {"type":"integer","minimum":1,"maximum":9007199254740991},
        "transport_epoch": {"type":"integer","minimum":1,"maximum":9007199254740991},
        "grant_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "superseded_authority_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "reason": {"enum":["outer_lease_lost","authority_revoked","worker_shutdown"]},
        "abandoned_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "abandonment_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"}
      }
    }
  ],

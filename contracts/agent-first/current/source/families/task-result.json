{
  "family_id": "task-result",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "task-result/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-semantics": {"document_rules":["task_result"],"contextual_helpers":["verify_task_result_context"]},
      "required": [
        "schema_id",
        "result_id",
        "task_id",
        "task_type",
        "result_source",
        "outcome",
        "reason_code",
        "summary",
        "outcome_details",
        "published_from_version",
        "terminal_task_version",
        "attempt_identity",
        "owner_identity",
        "request_ref",
        "policy_ref",
        "requirement_ledger_ref",
        "charter",
        "requirement_results",
        "original_source_state",
        "final_source_state",
        "execution_states",
        "change_set_ref",
        "completion_proposal",
        "observation_manifest",
        "attestations",
        "gate_decision",
        "evidence_closure_ref",
        "evidence_closure_digest",
        "effect_ledger_ref",
        "effects",
        "artifact_refs",
        "report",
        "budget_summary_ref",
        "provenance",
        "diagnostics",
        "created_at",
        "terminal_at"
      ],
      "properties": {
        "schema_id": {"const":"task-result/v1"},
        "result_id": {"type":"string","pattern":"^result_[0-9a-f]{32}$"},
        "task_id": {"type":"string","pattern":"^task_[0-9a-f]{32}$"},
        "task_type": {"type":"string","minLength":1,"maxLength":160},
        "result_source": {"const":"worker"},
        "outcome": {"enum":["COMPLETED","NO_CHANGE_NEEDED","COMPLETED_WITH_WAIVERS","PARTIAL","BLOCKED","FAILED","CANCELLED"]},
        "reason_code": {
          "enum": [
            "SUCCESS",
            "ALREADY_SATISFIED",
            "AUTHORIZED_WAIVER",
            "BUDGET_EXHAUSTED",
            "DEADLINE_REACHED",
            "VERIFICATION_INCOMPLETE",
            "CAPABILITY_UNAVAILABLE",
            "INTERACTION_UNAVAILABLE",
            "SAFE_PARTIAL_DELIVERY",
            "INPUT_REQUIRED",
            "APPROVAL_REQUIRED",
            "ENVIRONMENT_UNAVAILABLE",
            "POLICY_UNSUPPORTED",
            "RUNTIME_FAILURE",
            "STORAGE_FAILURE",
            "PROTOCOL_FAILURE",
            "QUALITY_GATE_FAILED",
            "POLICY_INVARIANT_BROKEN",
            "SOURCE_MUTATION_FORBIDDEN",
            "CONTRACT_INVALID",
            "USER_CANCELLED",
            "SERVER_CANCELLED",
            "LEASE_CANCELLED"
          ]
        },
        "summary": {"type":"string","minLength":1,"maxLength":4096},
        "outcome_details": {"$ref":"task-result-outcome-details/v1"},
        "published_from_version": {"type":"integer","minimum":1,"maximum":9007199254740990},
        "terminal_task_version": {"type":"integer","minimum":2,"maximum":9007199254740991},
        "attempt_identity": {"$ref":"attempt-identity/v1"},
        "owner_identity": {"$ref":"owner-identity/v1"},
        "request_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"task-request/v1"},
        "policy_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"effective-execution-policy/v1"},
        "requirement_ledger_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"requirement-ledger/v1"},
        "charter": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"task-charter/v1"},
        "requirement_results": {"type":"array","minItems":1,"maxItems":256,"uniqueItems":true,"items":{"$ref":"requirement-result/v1"}},
        "original_source_state": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"source-tree-manifest/v1"},
        "final_source_state": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"source-tree-manifest/v1"},
        "execution_states": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "uniqueItems": true,
          "items": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"execution-state-manifest/v1"}
        },
        "change_set_ref": {"oneOf":[{"$ref":"content-ref/v1","x-pullwise-content-schema-id":"change-set/v1"},{"type":"null"}]},
        "completion_proposal": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"completion-proposal/v1"},
        "observation_manifest": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"observation-manifest/v1"},
        "attestations": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"verification-attestation-manifest/v1"},
        "gate_decision": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"gate-decision/v1"},
        "evidence_closure_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"evidence-closure-manifest/v1"},
        "evidence_closure_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "effect_ledger_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"effect-ledger-snapshot/v1"},
        "effects": {
          "type": "object",
          "additionalProperties": false,
          "required": ["prepared","dispatched","committed","not_applied","rejected","unknown"],
          "properties": {"prepared":{"const":0},"dispatched":{"const":0},"committed":{"const":0},"not_applied":{"const":0},"rejected":{"const":0},"unknown":{"const":0}}
        },
        "artifact_refs": {"type":"array","maxItems":256,"uniqueItems":true,"items":{"$ref":"artifact-content-ref/v1"}},
        "report": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"task-report/v1"},
        "budget_summary_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"budget-summary/v1"},
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attempt_ids","checkpoint_generation","effective_policy_digest","control_plane_digest","evaluation_runtime_digest"],
          "properties": {
            "attempt_ids": {"type":"array","maxItems":256,"uniqueItems":true,"items":{"type":"string","pattern":"^attempt_[0-9a-f]{32}$"}},
            "checkpoint_generation": {"type":"integer","minimum":0,"maximum":9007199254740991},
            "effective_policy_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
            "control_plane_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
            "evaluation_runtime_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"}
          }
        },
        "diagnostics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["worker_debug_fragment"],
          "properties": {"worker_debug_fragment":{"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"worker-debug-fragment-descriptor/v1"}}
        },
        "created_at": {"type":"string","pattern":"^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,9})?Z$"},
        "terminal_at": {"type":"string","pattern":"^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,9})?Z$"}
      },
      "oneOf": [
        {"$ref":"task-result-completed-variant/v1"},
        {"$ref":"task-result-no-change-needed-variant/v1"},
        {"$ref":"task-result-completed-with-waivers-variant/v1"},
        {"$ref":"task-result-partial-variant/v1"},
        {"$ref":"task-result-blocked-variant/v1"},
        {"$ref":"task-result-failed-variant/v1"},
        {"$ref":"task-result-cancelled-variant/v1"}
      ]
    }
  ],

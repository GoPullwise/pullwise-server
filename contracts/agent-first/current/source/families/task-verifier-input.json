{
  "family_id": "task-verifier-input",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "verifier-input-manifest/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field":"input_manifest_digest","domain":"pullwise:verifier-input-manifest:v1"},
      "x-pullwise-semantics": {
        "document_rules": ["verifier_input_manifest"],
        "contextual_helpers": ["verify_verifier_input_context"]
      },
      "required": [
        "schema_id",
        "input_manifest_id",
        "task_id",
        "proposal_id",
        "slot_id",
        "task_request_ref",
        "effective_policy_ref",
        "requirement_ledger_ref",
        "charter_ref",
        "completion_proposal_ref",
        "quality_policy_plan_ref",
        "quality_policy_plan_digest",
        "original_source_ref",
        "final_source_ref",
        "change_set",
        "pre_verifier_observation_manifest_ref",
        "artifact_refs",
        "engineering_rule_refs",
        "slot_concern",
        "requirement_ids",
        "owner_conclusion_excluded",
        "created_at",
        "input_manifest_digest"
      ],
      "properties": {
        "schema_id": {"const":"verifier-input-manifest/v1"},
        "input_manifest_id": {"type":"string","pattern":"^vinput_[0-9a-f]{32}$"},
        "task_id": {"type":"string","pattern":"^task_[0-9a-f]{32}$"},
        "proposal_id": {"type":"string","pattern":"^proposal_[0-9a-f]{32}$"},
        "slot_id": {"type":"string","pattern":"^slot_[0-9a-f]{32}$"},
        "task_request_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"agent-task-request/v1"},
        "effective_policy_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"agent-task-policy/v1"},
        "requirement_ledger_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"requirement-ledger/v1"},
        "charter_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"task-charter/v1"},
        "completion_proposal_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"completion-proposal/v1"},
        "quality_policy_plan_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"quality-policy-plan/v1"},
        "quality_policy_plan_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "original_source_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"source-tree-manifest/v1"},
        "final_source_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"source-tree-manifest/v1"},
        "change_set": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"change-set/v1"},
        "pre_verifier_observation_manifest_ref": {
          "$ref": "content-ref/v1",
          "x-pullwise-content-schema-id": "pre-verifier-observation-manifest/v1"
        },
        "artifact_refs": {
          "type": "array",
          "maxItems": 4096,
          "uniqueItems": true,
          "items": {"$ref":"artifact-content-ref/v1"}
        },
        "engineering_rule_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "uniqueItems": true,
          "items": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"source-content/v1"}
        },
        "slot_concern": {"type":"string","minLength":1,"maxLength":4096},
        "requirement_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^req_(?:user_objective|user_acceptance|user_constraint|delivery|policy|interaction|derived)_[0-9a-f]{64}$"
          }
        },
        "owner_conclusion_excluded": {"const":true},
        "created_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "input_manifest_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"}
      }
    }
  ],

{
  "family_id": "task-publication",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "artifact-content-ref/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-semantics": ["artifact_content_ref"],
      "required": ["schema_id", "artifact_kind", "ref"],
      "properties": {
        "schema_id": {"const": "artifact-content-ref/v1"},
        "artifact_kind": {"enum": ["change_set_patch", "task_report"]},
        "ref": {
          "$ref": "content-ref/v1",
          "x-pullwise-content-schema-ids": ["change-set-patch/v1", "task-report/v1"]
        }
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "artifact-content-registry/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "registry_digest",
        "domain": "pullwise:artifact-content-registry:v1"
      },
      "x-pullwise-semantics": ["artifact_content_registry"],
      "required": ["schema_id", "entries", "registry_digest"],
      "properties": {
        "schema_id": {"const": "artifact-content-registry/v1"},
        "entries": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["artifact_kind", "content_schema_id", "media_type", "encoding"],
            "properties": {
              "artifact_kind": {"enum": ["change_set_patch", "task_report"]},
              "content_schema_id": {"enum": ["change-set-patch/v1", "task-report/v1"]},
              "media_type": {"const": "application/json"},
              "encoding": {"const": "utf-8"}
            }
          }
        },
        "registry_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "budget-summary/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "summary_digest",
        "domain": "pullwise:budget-summary:v1"
      },
      "x-pullwise-semantics": ["budget_summary"],
      "required": [
        "schema_id", "task_id", "grant_digest", "elapsed_limit_ms",
        "consumed_ms", "tool_call_limit", "calls_consumed",
        "unsettled_reservations", "summary_digest"
      ],
      "properties": {
        "schema_id": {"const": "budget-summary/v1"},
        "task_id": {"type": "string", "pattern": "^task_[0-9a-f]{32}$"},
        "grant_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "elapsed_limit_ms": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "consumed_ms": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
        "tool_call_limit": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "calls_consumed": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
        "unsettled_reservations": {"const": 0},
        "summary_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "effect-ledger-snapshot/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "ledger_digest",
        "domain": "pullwise:effect-ledger-snapshot:v1"
      },
      "x-pullwise-semantics": ["effect_ledger_snapshot"],
      "required": ["schema_id", "task_id", "watermark", "rows", "state_counts", "ledger_digest"],
      "properties": {
        "schema_id": {"const": "effect-ledger-snapshot/v1"},
        "task_id": {"type": "string", "pattern": "^task_[0-9a-f]{32}$"},
        "watermark": {"const": 0},
        "rows": {"const": []},
        "state_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["prepared", "dispatched", "committed", "not_applied", "rejected", "unknown"],
          "properties": {
            "prepared": {"const": 0},
            "dispatched": {"const": 0},
            "committed": {"const": 0},
            "not_applied": {"const": 0},
            "rejected": {"const": 0},
            "unknown": {"const": 0}
          }
        },
        "ledger_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "task-report/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "report_digest",
        "domain": "pullwise:task-report:v1"
      },
      "x-pullwise-semantics": ["task_report"],
      "required": ["schema_id", "task_id", "result_id", "title", "summary", "sections", "report_digest"],
      "properties": {
        "schema_id": {"const": "task-report/v1"},
        "task_id": {"type": "string", "pattern": "^task_[0-9a-f]{32}$"},
        "result_id": {"type": "string", "pattern": "^result_[0-9a-f]{32}$"},
        "title": {"type": "string", "minLength": 1, "maxLength": 512},
        "summary": {"type": "string", "minLength": 1, "maxLength": 4096},
        "sections": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["section_id", "title", "body", "evidence_refs"],
            "properties": {
              "section_id": {"type": "string", "pattern": "^section_[0-9a-f]{32}$"},
              "title": {"type": "string", "minLength": 1, "maxLength": 512},
              "body": {"type": "string", "minLength": 1, "maxLength": 65536},
              "evidence_refs": {
                "type": "array",
                "maxItems": 256,
                "uniqueItems": true,
                "items": {"$ref": "content-ref/v1"}
              }
            }
          }
        },
        "report_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "waiver-event/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "waiver_digest",
        "domain": "pullwise:waiver-event:v1"
      },
      "x-pullwise-semantics": ["waiver_event"],
      "required": [
        "schema_id", "waiver_id", "task_id", "requirement_ids", "issuer",
        "reason", "authorized_at", "expires_at", "waiver_digest"
      ],
      "properties": {
        "schema_id": {"const": "waiver-event/v1"},
        "waiver_id": {"type": "string", "pattern": "^waiver_[0-9a-f]{32}$"},
        "task_id": {"type": "string", "pattern": "^task_[0-9a-f]{32}$"},
        "requirement_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 160}
        },
        "issuer": {"$ref": "actor/v1"},
        "reason": {"type": "string", "minLength": 1, "maxLength": 4096},
        "authorized_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9:.]+Z$"},
        "expires_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9:.]+Z$"},
        "waiver_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  ],

{
  "family_id": "task-observation",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "observation/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "observation_digest",
        "domain": "pullwise:observation:v1"
      },
      "x-pullwise-semantics": {
        "document_rules": [
          "observation"
        ],
        "contextual_helpers": []
      },
      "required": [
        "schema_id",
        "observation_id",
        "task_id",
        "attempt_id",
        "native_epoch",
        "actor",
        "tool_id",
        "tool_version",
        "tool_invocation_id",
        "idempotency_key",
        "input_digest",
        "status",
        "started_at",
        "completed_at",
        "duration_ms",
        "exit_code",
        "source_state_before_id",
        "source_state_after_id",
        "execution_state_id",
        "stdout_ref",
        "stderr_ref",
        "result_ref",
        "redaction_report_ref",
        "partial_side_effect",
        "observation_seq",
        "observation_digest"
      ],
      "properties": {
        "schema_id": {
          "const": "observation/v1"
        },
        "observation_id": {
          "type": "string",
          "pattern": "^obs_[0-9a-f]{32}$"
        },
        "task_id": {
          "type": "string",
          "pattern": "^task_[0-9a-f]{32}$"
        },
        "attempt_id": {
          "type": "string",
          "pattern": "^attempt_[0-9a-f]{32}$"
        },
        "native_epoch": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "actor": {
          "$ref": "actor/v1"
        },
        "tool_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"
        },
        "tool_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "tool_invocation_id": {
          "type": "string",
          "pattern": "^toolinv_[0-9a-f]{32}$"
        },
        "idempotency_key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^[\\x21-\\x7e]+$"
        },
        "input_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "status": {
          "enum": [
            "cancelled",
            "failed",
            "infrastructure_error",
            "policy_denied",
            "policy_violation",
            "succeeded",
            "timed_out"
          ]
        },
        "started_at": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "completed_at": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "duration_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "exit_code": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": -2147483648,
          "maximum": 2147483647
        },
        "source_state_before_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "source_state_after_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "execution_state_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-f]{64}$"
        },
        "stdout_ref": {
          "$ref": "availability-ref/v1",
          "x-pullwise-availability-content-schema-id": "source-content/v1"
        },
        "stderr_ref": {
          "$ref": "availability-ref/v1",
          "x-pullwise-availability-content-schema-id": "source-content/v1"
        },
        "result_ref": {
          "$ref": "availability-ref/v1",
          "x-pullwise-availability-content-schema-ids": [
            "error-response/v1",
            "r0-read-result/v1"
          ]
        },
        "redaction_report_ref": {
          "$ref": "availability-ref/v1",
          "x-pullwise-availability-content-schema-id": "source-content/v1"
        },
        "partial_side_effect": {
          "const": false
        },
        "observation_seq": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "observation_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  ],

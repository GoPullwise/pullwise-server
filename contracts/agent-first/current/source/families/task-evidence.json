{
  "family_id": "task-evidence",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "evidence-closure-manifest/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field":"manifest_digest","domain":"pullwise:evidence-closure-manifest:v1"},
      "x-pullwise-semantics": {
        "document_rules": ["evidence_closure_manifest"],
        "contextual_helpers": ["verify_evidence_closure_context"]
      },
      "required": [
        "schema_id",
        "task_id",
        "pre_gate_evidence_closure_ref",
        "input_snapshot_ref",
        "gate_decision_ref",
        "entries",
        "entry_count",
        "evidence_closure_digest",
        "manifest_digest"
      ],
      "properties": {
        "schema_id": {"const":"evidence-closure-manifest/v1"},
        "task_id": {"type":"string","pattern":"^task_[0-9a-f]{32}$"},
        "pre_gate_evidence_closure_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"pre-gate-evidence-closure-manifest/v1"},
        "input_snapshot_ref": {
          "$ref": "content-ref/v1",
          "x-pullwise-content-schema-ids": ["gate-input-snapshot/v1","terminalization-input-snapshot/v1"]
        },
        "gate_decision_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"gate-decision/v1"},
        "entries": {
          "type": "array",
          "minItems": 9,
          "maxItems": 4099,
          "uniqueItems": true,
          "items": {
            "$ref": "content-ref/v1",
            "x-pullwise-content-schema-ids": [
              "budget-summary/v1",
              "canonical-document/v1",
              "change-set-patch/v1",
              "change-set/v1",
              "completion-proposal/v1",
              "debug-redaction-plan/v1",
              "effect-ledger-snapshot/v1",
              "effective-execution-policy/v1",
              "error-response/v1",
              "execution-profile/v1",
              "execution-state-manifest/v1",
              "gate-decision/v1",
              "gate-input-snapshot/v1",
              "local-tool-receipt/v1",
              "observation-manifest/v1",
              "observation/v1",
              "pre-gate-evidence-closure-manifest/v1",
              "pre-gate-root-set/v1",
              "pre-verifier-observation-manifest/v1",
              "publication-content-manifest/v1",
              "quality-policy-plan/v1",
              "r0-read-payload/v1",
              "r0-read-result/v1",
              "requirement-ledger/v1",
              "source-content/v1",
              "source-selection-policy/v1",
              "source-tree-manifest/v1",
              "stable-error/v1",
              "task-charter/v1",
              "task-report/v1",
              "task-request/v1",
              "terminalization-fact/v1",
              "terminalization-input-snapshot/v1",
              "verification-attestation-manifest/v1",
              "verification-attestation/v1",
              "verifier-input-manifest/v1",
              "verifier-work-report/v1",
              "waiver-event/v1"
            ]
          }
        },
        "entry_count": {"type":"integer","minimum":9,"maximum":4099},
        "evidence_closure_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "manifest_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"}
      }
    }
  ],

{
  "family_id": "quality-policy-plan",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "quality-policy-plan/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field":"plan_digest","domain":"pullwise:quality-policy-plan:v1"},
      "x-pullwise-semantics": {
        "document_rules": ["quality_policy_plan"],
        "contextual_helpers": ["verify_quality_policy_plan_context"]
      },
      "required": [
        "schema_id", "task_id", "proposal_id", "proposal_digest", "policy_digest", "task_type", "requirement_ledger_digest",
        "change_set_classification_digest", "capability_usage_digest", "input_digest", "quality_risk", "slots",
        "self_attestation_allowed", "rationale", "policy_implementation_version", "plan_digest"
      ],
      "properties": {
        "schema_id": {"const":"quality-policy-plan/v1"},
        "task_id": {"type":"string","pattern":"^task_[0-9a-f]{32}$"},
        "proposal_id": {"type":"string","pattern":"^proposal_[0-9a-f]{32}$"},
        "proposal_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "policy_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "task_type": {"const":"pullwise.repo-review.full-scan/v1"},
        "requirement_ledger_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "change_set_classification_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "capability_usage_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "input_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "quality_risk": {"enum":["Q1","Q2","Q3"]},
        "slots": {
          "type": "array",
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["slot_id","concern","requirement_ids"],
            "properties": {
              "slot_id": {"type":"string","pattern":"^slot_[0-9a-f]{32}$"},
              "concern": {"enum":["contract_and_data","security_and_concurrency"]},
              "requirement_ids": {
                "type": "array",
                "minItems": 1,
                "maxItems": 256,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "pattern": "^req_(?:user_objective|user_acceptance|user_constraint|delivery|policy|interaction|derived)_[0-9a-f]{64}$"
                }
              }
            }
          }
        },
        "self_attestation_allowed": {"const":false},
        "rationale": {"type":"string","minLength":1,"maxLength":4096},
        "policy_implementation_version": {"const":"pullwise-quality-policy/v1"},
        "plan_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"}
      },
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "quality_risk": {"const":"Q1"},
            "slots": {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "items": {
                "type": "object",
                "properties": {
                  "concern": {"const":"contract_and_data"}
                }
              }
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "quality_risk": {"const":"Q2"},
            "slots": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "quality_risk": {"const":"Q3"},
            "slots": {
              "type": "array",
              "minItems": 0,
              "maxItems": 0
            }
          }
        }
      ]
    }
  ],

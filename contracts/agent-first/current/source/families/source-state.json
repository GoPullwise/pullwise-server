{
  "family_id": "source-state",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "source-selection-policy/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "policy_digest",
        "domain": "pullwise:source-selection-policy/v1"
      },
      "x-pullwise-semantics": [
        "source_selection_policy"
      ],
      "required": [
        "schema_id",
        "root_identity",
        "include",
        "excluded_control_roots",
        "ephemeral_patterns",
        "symlink_policy",
        "case_collision_policy",
        "policy_digest"
      ],
      "properties": {
        "schema_id": {
          "const": "source-selection-policy/v1"
        },
        "root_identity": {
          "type": "string",
          "pattern": "^root_[0-9a-f]{32}$"
        },
        "include": {
          "const": "all_repository_regular_files"
        },
        "excluded_control_roots": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 4096
          }
        },
        "ephemeral_patterns": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096
          }
        },
        "symlink_policy": {
          "const": "record_target_no_follow"
        },
        "case_collision_policy": {
          "const": "reject"
        },
        "policy_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "source-tree-manifest/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "manifest_digest",
        "domain": "pullwise:source-tree-manifest/v1"
      },
      "x-pullwise-semantics": [
        "source_tree_manifest"
      ],
      "required": [
        "schema_id",
        "base_revision",
        "selection_policy_ref",
        "selection_policy_digest",
        "entries",
        "entry_count",
        "total_bytes",
        "source_state_id",
        "manifest_digest"
      ],
      "properties": {
        "schema_id": {
          "const": "source-tree-manifest/v1"
        },
        "base_revision": {
          "type": "string",
          "pattern": "^(?:[0-9a-f]{40}|unversioned:[0-9a-f]{64})$"
        },
        "selection_policy_ref": {
          "$ref": "content-ref/v1",
          "x-pullwise-content-schema-id": "source-selection-policy/v1"
        },
        "selection_policy_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "entries": {
          "type": "array",
          "maxItems": 1000000,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "type"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "maxLength": 4096,
                "pattern": "^[^\\x00\\\\]+$"
              },
              "type": {
                "enum": [
                  "file",
                  "gitlink",
                  "symlink"
                ]
              },
              "size_bytes": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "executable": {
                "type": "boolean"
              },
              "target": {
                "type": "string",
                "maxLength": 4096
              },
              "commit_sha": {
                "type": "string",
                "pattern": "^[0-9a-f]{40}$"
              }
            }
          }
        },
        "entry_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "total_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "source_state_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "manifest_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  ],

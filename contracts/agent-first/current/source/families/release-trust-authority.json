{
  "family_id": "release-trust-authority",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "release-principal/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "principal_digest",
        "domain": "pullwise:release-principal:v1"
      },
      "x-pullwise-semantics": {
        "document_rules": ["release_principal"],
        "contextual_helpers": [],
        "signature_contract": {
          "algorithm": "Ed25519",
          "domain": "pullwise-release-principal/v1",
          "domain_separator": "NUL",
          "encoding": "base64url_no_padding",
          "signed_projection": "document_without_signature_and_digest"
        }
      },
      "required": [
        "schema_id", "principal_id", "organization_id", "role",
        "trust_root_id", "trust_root_ref", "trust_root_digest",
        "signer_id", "key_id", "signature_algorithm", "signature",
        "issued_at", "expires_at", "principal_digest"
      ],
      "properties": {
        "schema_id": {"const": "release-principal/v1"},
        "principal_id": {
          "type": "string",
          "pattern": "^principal_[a-z0-9_]{1,64}$"
        },
        "organization_id": {
          "type": "string",
          "pattern": "^org_[a-z0-9_]{1,64}$"
        },
        "role": {"enum": ["benchmark_owner", "release_operator"]},
        "trust_root_id": {
          "type": "string",
          "pattern": "^release_trust_root_[0-9a-f]{32}$"
        },
        "trust_root_ref": {
          "$ref": "content-ref/v1",
          "x-pullwise-content-schema-id": "release-trust-root/v1"
        },
        "trust_root_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "signer_id": {
          "type": "string",
          "pattern": "^principal_[a-z0-9_]{1,64}$"
        },
        "key_id": {
          "type": "string",
          "pattern": "^key_[A-Za-z0-9_-]{1,96}$"
        },
        "signature_algorithm": {"const": "Ed25519"},
        "signature": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{86}$"
        },
        "issued_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "expires_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "principal_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },

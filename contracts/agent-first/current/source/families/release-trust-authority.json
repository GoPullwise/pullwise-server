{
  "family_id": "release-trust-authority",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "release-trust-root/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "root_digest",
        "domain": "pullwise:release-trust-root:v1"
      },
      "required": [
        "schema_id",
        "trust_root_id",
        "organization_id",
        "root_principal_id",
        "root_key_id",
        "signature_algorithm",
        "public_key",
        "issued_at",
        "expires_at",
        "root_digest"
      ],
      "properties": {
        "schema_id": {"const": "release-trust-root/v1"},
        "trust_root_id": {
          "type": "string",
          "pattern": "^release_trust_root_[0-9a-f]{32}$"
        },
        "organization_id": {
          "type": "string",
          "pattern": "^org_[a-z0-9_]{1,64}$"
        },
        "root_principal_id": {
          "type": "string",
          "pattern": "^principal_[a-z0-9_]{1,64}$"
        },
        "root_key_id": {
          "type": "string",
          "pattern": "^key_[A-Za-z0-9_-]{1,96}$"
        },
        "signature_algorithm": {"const": "Ed25519"},
        "public_key": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{43}$"
        },
        "issued_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "expires_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "root_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  ],
  "fixtures": []
}

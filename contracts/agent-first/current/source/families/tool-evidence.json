{
  "family_id": "tool-evidence",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "agent-tool-request/v1",
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "idempotency_key", "tool_key", "tool_input"],
      "properties": {
        "schema_id": {"const": "agent-tool-request/v1"},
        "idempotency_key": {"type": "string", "minLength": 1, "maxLength": 160},
        "tool_key": {"const": "internal.read_source"},
        "tool_input": {
          "type": "object",
          "additionalProperties": false,
          "required": ["relative_path"],
          "properties": {"relative_path": {"type": "string", "minLength": 1, "maxLength": 4096}}
        }
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "local-tool-receipt/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field": "receipt_digest", "domain": "pullwise:local-tool-receipt:v1"},
      "required": ["schema_id", "receipt_kind", "tool_key", "invocation_digest", "status", "result_ref", "started_at", "completed_at", "elapsed_ms", "receipt_digest"],
      "properties": {
        "schema_id": {"const": "local-tool-receipt/v1"},
        "receipt_kind": {"const": "local_tool"},
        "tool_key": {"const": "internal.read_source"},
        "invocation_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "status": {"enum": ["succeeded", "failed", "cancelled", "timed_out", "policy_violation"]},
        "result_ref": {"$ref": "content-ref/v1"},
        "started_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9:.]+Z$"},
        "completed_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9:.]+Z$"},
        "elapsed_ms": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
        "receipt_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "observation/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field": "observation_digest", "domain": "pullwise:observation:v1"},
      "required": ["schema_id", "observation_id", "task_id", "attempt_id", "native_epoch", "tool_key", "invocation_digest", "local_receipt_digest", "status", "source_state_before_id", "source_state_after_id", "result_ref", "observation_digest"],
      "properties": {
        "schema_id": {"const": "observation/v1"},
        "observation_id": {"type": "string", "pattern": "^obs_[0-9a-f]{32}$"},
        "task_id": {"type": "string", "pattern": "^task_[0-9a-f]{32}$"},
        "attempt_id": {"type": "string", "pattern": "^attempt_[0-9a-f]{32}$"},
        "native_epoch": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "tool_key": {"const": "internal.read_source"},
        "invocation_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "local_receipt_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "status": {"enum": ["succeeded", "failed", "cancelled", "timed_out", "policy_violation", "infrastructure_error"]},
        "source_state_before_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "source_state_after_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "result_ref": {"$ref": "content-ref/v1"},
        "observation_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "r0-read-result/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field": "result_digest", "domain": "pullwise:r0-read-result:v1"},
      "required": ["schema_id", "invocation_digest", "relative_path", "source_state_before_id", "source_state_after_id", "content_ref", "result_digest"],
      "properties": {
        "schema_id": {"const": "r0-read-result/v1"},
        "invocation_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "relative_path": {"type": "string", "minLength": 1, "maxLength": 4096},
        "source_state_before_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "source_state_after_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "content_ref": {"$ref": "content-ref/v1"},
        "result_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "source-state/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field": "source_state_id", "domain": "pullwise:source-state:v1"},
      "required": ["schema_id", "task_id", "attempt_id", "native_epoch", "repository_root_id", "entry_count", "manifest_sha256", "source_state_id"],
      "properties": {
        "schema_id": {"const": "source-state/v1"},
        "task_id": {"type": "string", "pattern": "^task_[0-9a-f]{32}$"},
        "attempt_id": {"type": "string", "pattern": "^attempt_[0-9a-f]{32}$"},
        "native_epoch": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "repository_root_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "entry_count": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
        "manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "source_state_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "tool-catalog/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field": "catalog_digest", "domain": "pullwise:tool-catalog:v1"},
      "required": ["schema_id", "tools", "catalog_digest"],
      "properties": {
        "schema_id": {"const": "tool-catalog/v1"},
        "tools": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["tool_key", "capability_id", "risk", "request_schema_id", "result_schema_id"],
            "properties": {
              "tool_key": {"const": "internal.read_source"},
              "capability_id": {"const": "source.read"},
              "risk": {"const": "R0"},
              "request_schema_id": {"const": "agent-tool-request/v1"},
              "result_schema_id": {"const": "r0-read-result/v1"}
            }
          }
        },
        "catalog_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "tool-dispatch-intent/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field": "intent_digest", "domain": "pullwise:tool-dispatch-intent:v1"},
      "required": ["schema_id", "package", "intent_id", "authority_digest", "grant_digest", "invocation_digest", "reservation_id", "capability_digest", "state", "created_at", "intent_digest"],
      "properties": {
        "schema_id": {"const": "tool-dispatch-intent/v1"},
        "package": {"$ref": "contract-package-tuple/v1"},
        "intent_id": {"type": "string", "pattern": "^intent_[0-9a-f]{32}$"},
        "authority_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "grant_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "invocation_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "reservation_id": {"type": "string", "pattern": "^reserve_[0-9a-f]{32}$"},
        "capability_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "state": {"enum": ["INTENT", "DISPATCHED", "SETTLED", "ABANDONED"]},
        "created_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9:.]+Z$"},
        "intent_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "tool-invocation/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field": "invocation_digest", "domain": "pullwise:tool-invocation:v1"},
      "required": ["schema_id", "package", "authority_digest", "grant_digest", "task_id", "attempt_id", "session_id", "owner_id", "lease_id", "task_version", "deletion_version", "owner_epoch", "native_epoch", "transport_epoch", "idempotency_key", "tool_key", "tool_input", "invocation_digest"],
      "properties": {
        "schema_id": {"const": "tool-invocation/v1"},
        "package": {"$ref": "contract-package-tuple/v1"},
        "authority_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "grant_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "task_id": {"type": "string", "pattern": "^task_[0-9a-f]{32}$"},
        "attempt_id": {"type": "string", "pattern": "^attempt_[0-9a-f]{32}$"},
        "session_id": {"type": "string", "pattern": "^sess_[0-9a-f]{32}$"},
        "owner_id": {"type": "string", "pattern": "^owner_[0-9a-f]{32}$"},
        "lease_id": {"type": "string", "pattern": "^lease_[0-9a-f]{32}$"},
        "task_version": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "deletion_version": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
        "owner_epoch": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "native_epoch": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "transport_epoch": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "idempotency_key": {"type": "string", "minLength": 1, "maxLength": 160},
        "tool_key": {"const": "internal.read_source"},
        "tool_input": {
          "type": "object",
          "additionalProperties": false,
          "required": ["relative_path"],
          "properties": {"relative_path": {"type": "string", "minLength": 1, "maxLength": 4096}}
        },
        "invocation_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  ],
  "fixtures": [
    {
      "fixture_id": "tool_crash_after_intent",
      "fixture_class": "crash",
      "schema_id": "tool-dispatch-intent/v1",
      "document": {"persisted_state": "INTENT", "capability_consumed": false},
      "expected_code": "INVOCATION_PENDING"
    },
    {
      "fixture_id": "tool_golden_local_receipt",
      "fixture_class": "golden",
      "schema_id": "local-tool-receipt/v1",
      "document": {"receipt_kind": "local_tool", "status": "succeeded"},
      "expected_code": null
    },
    {
      "fixture_id": "tool_negative_agent_selected_authority",
      "fixture_class": "negative",
      "schema_id": "agent-tool-request/v1",
      "document": {"owner_epoch": 9, "tool_key": "internal.read_source"},
      "expected_code": "AUTHORITY_INPUT_UNTRUSTED"
    }
  ]
}

        "change_set": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"change-set/v1"},
        "pre_observation_manifest_ref": {
          "$ref":"content-ref/v1", "x-pullwise-content-schema-id":"pre-verifier-observation-manifest/v1"

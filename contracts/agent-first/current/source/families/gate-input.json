        "terminal_budget_reserved_ms": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "predicate_registry_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "request_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"task-request/v1"},
        "policy_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"effective-execution-policy/v1"},
        "requirement_ledger_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"requirement-ledger/v1"},
        "completion_proposal_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"completion-proposal/v1"},
        "quality_policy_plan_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"quality-policy-plan/v1"},
        "original_source_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"source-tree-manifest/v1"},
        "final_source_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"source-tree-manifest/v1"},
        "execution_state_refs": {
          "type":"array", "maxItems":256, "uniqueItems":true,
          "items":{"$ref":"content-ref/v1","x-pullwise-content-schema-id":"execution-state-manifest/v1"}

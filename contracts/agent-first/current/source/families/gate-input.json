        "publication_content_manifest_ref": {
          "$ref":"content-ref/v1", "x-pullwise-content-schema-id":"publication-content-manifest/v1"
        },
        "debug_redaction_plan_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"debug-redaction-plan/v1"},

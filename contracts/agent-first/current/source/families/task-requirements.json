{
  "family_id": "task-requirements",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "requirement-entry/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-semantics": [
        "canonical_source_tuple_identity",
        "derived_requirement_authority",
        "requirement_id_source_kind_match",
        "sorted_unique_requirement_links",
        "utf8_nfc_byte_limits"
      ],
      "required": [
        "schema_id",
        "requirement_id",
        "source_kind",
        "source_id",
        "statement",
        "mandatory",
        "necessity",
        "parent_requirement_ids",
        "introduced_by",
        "introduced_at",
        "ledger_version",
        "rationale",
        "supersedes"
      ],
      "properties": {
        "schema_id": {"const": "requirement-entry/v1"},
        "requirement_id": {
          "type": "string",
          "pattern": "^req_(?:user_objective|user_acceptance|user_constraint|delivery|policy|interaction|derived)_[0-9a-f]{64}$"
        },
        "source_kind": {
          "enum": [
            "user_objective",
            "user_acceptance",
            "user_constraint",
            "delivery",
            "policy",
            "interaction",
            "derived"
          ]
        },
        "source_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[\\x21-\\x7e]+$"
        },
        "statement": {"type": "string", "minLength": 1, "maxLength": 16384},
        "mandatory": {"type": "boolean"},
        "necessity": {
          "enum": [
            "explicit",
            "mechanically_necessary",
            "safety_necessary",
            "advisory"
          ]
        },
        "parent_requirement_ids": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^req_(?:user_objective|user_acceptance|user_constraint|delivery|policy|interaction|derived)_[0-9a-f]{64}$"
          }
        },
        "introduced_by": {"$ref": "actor/v1"},
        "introduced_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "ledger_version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "rationale": {"type": "string", "maxLength": 16384},
        "supersedes": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^req_derived_[0-9a-f]{64}$"
          }
        }
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "requirement-ledger/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "ledger_digest",
        "domain": "pullwise:requirement-ledger:v1"
      },
      "x-pullwise-semantics": [
        "active_set_exact",
        "derived_graph_acyclic_same_task_lower_version",
        "entries_source_tuple_ordered",
        "entry_ledger_versions_valid",
        "ledger_digest_exact"
      ],
      "required": [
        "schema_id",
        "task_id",
        "ledger_version",
        "entries",
        "active_requirement_ids",
        "ledger_digest"
      ],
      "properties": {
        "schema_id": {"const": "requirement-ledger/v1"},
        "task_id": {"type": "string", "pattern": "^task_[0-9a-f]{32}$"},
        "ledger_version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4096,
          "uniqueItems": true,
          "items": {"$ref": "requirement-entry/v1"}
        },
        "active_requirement_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4096,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^req_(?:user_objective|user_acceptance|user_constraint|delivery|policy|interaction|derived)_[0-9a-f]{64}$"
          }
        },
        "ledger_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "task-charter/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "digest",
        "domain": "pullwise:task-charter:v1"
      },
      "x-pullwise-semantics": [
        "charter_digest_exact",
        "previous_charter_exact_predecessor",
        "sorted_unique_charter_sets",
        "utf8_nfc_byte_limits"
      ],
      "required": [
        "schema_id",
        "task_id",
        "charter_version",
        "previous_charter_ref",
        "objective_restated",
        "scope_in",
        "scope_out",
        "assumptions",
        "plan",
        "requirement_ids",
        "unresolved_questions",
        "delivery_plan",
        "created_by",
        "created_at",
        "digest"
      ],
      "properties": {
        "schema_id": {"const": "task-charter/v1"},
        "task_id": {"type": "string", "pattern": "^task_[0-9a-f]{32}$"},
        "charter_version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "previous_charter_ref": {
          "oneOf": [
            {
              "$ref": "content-ref/v1",
              "x-pullwise-content-schema-id": "task-charter/v1"
            },
            {"type": "null"}
          ]
        },
        "objective_restated": {
          "type": "string",
          "minLength": 1,
          "maxLength": 16384
        },
        "scope_in": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 4096}
        },
        "scope_out": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 4096}
        },
        "assumptions": {
          "type": "array",
          "maxItems": 256,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["statement", "impact", "reversible"],
            "properties": {
              "statement": {"type": "string", "minLength": 1, "maxLength": 16384},
              "impact": {"type": "string", "minLength": 1, "maxLength": 4096},
              "reversible": {"type": "boolean"}
            }
          }
        },
        "plan": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {"type": "string", "minLength": 1, "maxLength": 4096}
        },
        "requirement_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 512,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^req_(?:user_objective|user_acceptance|user_constraint|delivery|policy|interaction|derived)_[0-9a-f]{64}$"
          }
        },
        "unresolved_questions": {
          "type": "array",
          "maxItems": 256,
          "items": {"type": "string", "minLength": 1, "maxLength": 4096}
        },
        "delivery_plan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "required_outputs", "output_language"],
          "properties": {
            "kind": {"type": "string", "minLength": 1, "maxLength": 80},
            "required_outputs": {
              "type": "array",
              "maxItems": 64,
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1, "maxLength": 160}
            },
            "output_language": {"type": "string", "minLength": 1, "maxLength": 35}
          }
        },
        "created_by": {"$ref": "actor/v1"},
        "created_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "waiver-event/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-semantics": [
        "ed25519_signature_binding",
        "issuer_policy_authority",
        "revocation_target_rules",
        "waiver_time_window"
      ],
      "required": [
        "schema_id",
        "waiver_id",
        "task_id",
        "requirement_id",
        "waived_ledger_version",
        "ledger_digest",
        "policy_version",
        "scope",
        "issuer",
        "key_id",
        "reason",
        "issued_at",
        "expires_at",
        "revokes_waiver_id",
        "signature"
      ],
      "properties": {
        "schema_id": {"const": "waiver-event/v1"},
        "waiver_id": {"type": "string", "pattern": "^waiver_[0-9a-f]{32}$"},
        "task_id": {"type": "string", "pattern": "^task_[0-9a-f]{32}$"},
        "requirement_id": {
          "type": "string",
          "pattern": "^req_(?:user_objective|user_acceptance|user_constraint|delivery|policy|interaction|derived)_[0-9a-f]{64}$"
        },
        "waived_ledger_version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "ledger_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "policy_version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "scope": {"const": "this_requirement_this_ledger_version"},
        "issuer": {"type": "string", "minLength": 1, "maxLength": 160},
        "key_id": {"type": "string", "minLength": 1, "maxLength": 160},
        "reason": {"type": "string", "minLength": 1, "maxLength": 16384},
        "issued_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "expires_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "revokes_waiver_id": {
          "type": ["string", "null"],
          "pattern": "^waiver_[0-9a-f]{32}$"
        },
        "signature": {"type": "string", "pattern": "^[A-Za-z0-9_-]{86}$"}
      }
    }
  ],

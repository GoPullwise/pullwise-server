      required: [schema_id, source_state_id, execution_profile_ref, execution_profile_digest, toolchain, config_and_fixtures, services, environment, locale, timezone, execution_state_id, manifest_digest],
      properties: {
        schema_id: {const: execution-state-manifest/v1},
        source_state_id: {type: string, pattern: ^[0-9a-f]{64}$},
        execution_profile_ref: {$ref: content-ref/v1, x-pullwise-content-schema-id: execution-profile/v1},
        execution_profile_digest: {type: string, pattern: ^[0-9a-f]{64}$},
        toolchain: {
          type: array, maxItems: 4096, uniqueItems: true,
          items: {type: object, additionalProperties: false, required: [tool_id, binary_identity, version, binary_sha256], properties: {tool_id: {type: string, minLength: 1, maxLength: 160, pattern: ^[A-Za-z0-9][A-Za-z0-9._:/-]*$}, binary_identity: {type: string, minLength: 2, maxLength: 4096, pattern: ^/[^\\x00]+$}, version: {type: string, minLength: 1, maxLength: 160}, binary_sha256: {type: string, pattern: ^[0-9a-f]{64}$}}}
        },
        config_and_fixtures: {type: array, maxItems: 4096, uniqueItems: true, items: {$ref: content-ref/v1, x-pullwise-content-schema-id: source-content/v1}},
        services: {
          type: array, maxItems: 4096, uniqueItems: true,
          items: {type: object, additionalProperties: false, required: [service_id, version, endpoint_class, fingerprint], properties: {service_id: {type: string, minLength: 1, maxLength: 160, pattern: ^[A-Za-z0-9][A-Za-z0-9._:/-]*$}, version: {type: string, minLength: 1, maxLength: 160}, endpoint_class: {enum: [local_process, loopback, private_network, public_network]}, fingerprint: {type: string, pattern: ^[0-9a-f]{64}$}}}
        },
        environment: {
          type: array, maxItems: 4096, uniqueItems: true,
          items: {type: object, additionalProperties: false, required: [kind, key], properties: {kind: {enum: [secret_ref, value]}, key: {type: string, minLength: 1, maxLength: 160, pattern: ^[A-Z_][A-Z0-9_]*$}, value: {type: string, maxLength: 4096}, secret_key_id: {type: string, pattern: ^secret_[0-9a-f]{32}$}, secret_version: {type: string, minLength: 1, maxLength: 160}}}
        },
        locale: {type: string, minLength: 1, maxLength: 64},
        timezone: {type: string, minLength: 1, maxLength: 64},
        execution_state_id: {type: string, pattern: ^[0-9a-f]{64}$},
        manifest_digest: {type: string, pattern: ^[0-9a-f]{64}$}
      }
    },
    {
      $schema: https://json-schema.org/draft/2020-12/schema,
      $id: source-selection-policy/v1,
      type: object,
      additionalProperties: false,
      x-pullwise-digest: {field: policy_digest, domain: pullwise:source-selection-policy:v1},
      x-pullwise-semantics: [source_selection_policy],
      required: [schema_id, root_identity, include, excluded_control_roots, ephemeral_patterns, symlink_policy, case_collision_policy, policy_digest],
      properties: {
        schema_id: {const: source-selection-policy/v1},
        root_identity: {type: string, pattern: ^root_[0-9a-f]{32}$},
        include: {const: all_repository_regular_files},
        excluded_control_roots: {type: array, minItems: 1, maxItems: 128, uniqueItems: true, items: {type: string, minLength: 2, maxLength: 4096}},
        ephemeral_patterns: {type: array, maxItems: 128, uniqueItems: true, items: {type: string, minLength: 1, maxLength: 4096}},
        symlink_policy: {const: record_target_no_follow},
        case_collision_policy: {const: reject},
        policy_digest: {type: string, pattern: ^[0-9a-f]{64}$}
      }
    },
    {
      $schema: https://json-schema.org/draft/2020-12/schema,
      $id: source-tree-manifest/v1,
      type: object,
      additionalProperties: false,
      x-pullwise-digest: {field: manifest_digest, domain: pullwise:source-tree-manifest:v1},

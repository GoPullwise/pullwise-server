      required: [schema_id, base_revision, selection_policy_ref, selection_policy_digest, entries, entry_count, total_bytes, source_state_id, manifest_digest],
      properties: {
        schema_id: {const: source-tree-manifest/v1},
        base_revision: {type: string, pattern: ^(?:[0-9a-f]{40}|unversioned:[0-9a-f]{64})$},
        selection_policy_ref: {$ref: content-ref/v1, x-pullwise-content-schema-id: source-selection-policy/v1},
        selection_policy_digest: {type: string, pattern: ^[0-9a-f]{64}$},
        entries: {
          type: array, maxItems: 1000000, uniqueItems: true,
          items: {type: object, additionalProperties: false, required: [path, type], properties: {path: {type: string, minLength: 1, maxLength: 4096, pattern: ^[^\\x00\\\\]+$}, type: {enum: [file, gitlink, symlink]}, size_bytes: {type: integer, minimum: 0, maximum: 9007199254740991}, sha256: {type: string, pattern: ^[0-9a-f]{64}$}, executable: {type: boolean}, target: {type: string, maxLength: 4096}, commit_sha: {type: string, pattern: ^[0-9a-f]{40}$}}}
        },
        entry_count: {type: integer, minimum: 0, maximum: 9007199254740991},
        total_bytes: {type: integer, minimum: 0, maximum: 9007199254740991},
        source_state_id: {type: string, pattern: ^[0-9a-f]{64}$},
        manifest_digest: {type: string, pattern: ^[0-9a-f]{64}$}
      }
    }
  ],

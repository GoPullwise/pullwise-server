{
  "family_id": "source-evidence",
  schemas: [
    {
      $schema: https://json-schema.org/draft/2020-12/schema,
      $id: change-set-patch/v1,
      type: object,
      additionalProperties: false,
      x-pullwise-digest: {field: patch_digest, domain: pullwise:change-set-patch:v1},
      x-pullwise-semantics: [change_set_patch],
      required: [schema_id, format, media_type, encoding, data_base64, byte_sha256, size_bytes, patch_digest],
      properties: {
        schema_id: {const: change-set-patch/v1},
        format: {const: unified_diff},
        media_type: {const: text/x-diff},
        encoding: {const: base64},
        data_base64: {type: string, pattern: ^[A-Za-z0-9+/]*={0,2}$},
        byte_sha256: {type: string, pattern: ^[0-9a-f]{64}$},
        size_bytes: {type: integer, minimum: 0, maximum: 9007199254740991},
        patch_digest: {type: string, pattern: ^[0-9a-f]{64}$}
      }
    },
    {
      $schema: https://json-schema.org/draft/2020-12/schema,
      $id: change-set/v1,
      type: object,
      additionalProperties: false,
      x-pullwise-digest: {field: change_set_digest, domain: pullwise:change-set:v1},
      x-pullwise-semantics: [change_set],
      required: [schema_id, original_source_state_id, final_source_state_id, added, modified, deleted, type_changed, patch_ref, change_set_digest],
      properties: {
        schema_id: {const: change-set/v1},
        original_source_state_id: {type: string, pattern: ^[0-9a-f]{64}$},
        final_source_state_id: {type: string, pattern: ^[0-9a-f]{64}$},
        added: {
          type: array, maxItems: 1000000, uniqueItems: true,
          items: {
            type: object, additionalProperties: false, required: [],
            properties: {
              before: {type: object, additionalProperties: false, required: [path, type], properties: {path: {type: string, minLength: 1, maxLength: 4096, pattern: ^[^\\x00\\\\]+$}, type: {enum: [file, gitlink, symlink]}, size_bytes: {type: integer, minimum: 0, maximum: 9007199254740991}, sha256: {type: string, pattern: ^[0-9a-f]{64}$}, executable: {type: boolean}, target: {type: string, maxLength: 4096}, commit_sha: {type: string, pattern: ^[0-9a-f]{40}$}}},
              after: {type: object, additionalProperties: false, required: [path, type], properties: {path: {type: string, minLength: 1, maxLength: 4096, pattern: ^[^\\x00\\\\]+$}, type: {enum: [file, gitlink, symlink]}, size_bytes: {type: integer, minimum: 0, maximum: 9007199254740991}, sha256: {type: string, pattern: ^[0-9a-f]{64}$}, executable: {type: boolean}, target: {type: string, maxLength: 4096}, commit_sha: {type: string, pattern: ^[0-9a-f]{40}$}}}
            }
          }
        },
        modified: {
          type: array, maxItems: 1000000, uniqueItems: true,
          items: {
            type: object, additionalProperties: false, required: [],
            properties: {
              before: {type: object, additionalProperties: false, required: [path, type], properties: {path: {type: string, minLength: 1, maxLength: 4096, pattern: ^[^\\x00\\\\]+$}, type: {enum: [file, gitlink, symlink]}, size_bytes: {type: integer, minimum: 0, maximum: 9007199254740991}, sha256: {type: string, pattern: ^[0-9a-f]{64}$}, executable: {type: boolean}, target: {type: string, maxLength: 4096}, commit_sha: {type: string, pattern: ^[0-9a-f]{40}$}}},
              after: {type: object, additionalProperties: false, required: [path, type], properties: {path: {type: string, minLength: 1, maxLength: 4096, pattern: ^[^\\x00\\\\]+$}, type: {enum: [file, gitlink, symlink]}, size_bytes: {type: integer, minimum: 0, maximum: 9007199254740991}, sha256: {type: string, pattern: ^[0-9a-f]{64}$}, executable: {type: boolean}, target: {type: string, maxLength: 4096}, commit_sha: {type: string, pattern: ^[0-9a-f]{40}$}}}
            }
          }
        },
        deleted: {
          type: array, maxItems: 1000000, uniqueItems: true,
          items: {
            type: object, additionalProperties: false, required: [],
            properties: {
              before: {type: object, additionalProperties: false, required: [path, type], properties: {path: {type: string, minLength: 1, maxLength: 4096, pattern: ^[^\\x00\\\\]+$}, type: {enum: [file, gitlink, symlink]}, size_bytes: {type: integer, minimum: 0, maximum: 9007199254740991}, sha256: {type: string, pattern: ^[0-9a-f]{64}$}, executable: {type: boolean}, target: {type: string, maxLength: 4096}, commit_sha: {type: string, pattern: ^[0-9a-f]{40}$}}},
              after: {type: object, additionalProperties: false, required: [path, type], properties: {path: {type: string, minLength: 1, maxLength: 4096, pattern: ^[^\\x00\\\\]+$}, type: {enum: [file, gitlink, symlink]}, size_bytes: {type: integer, minimum: 0, maximum: 9007199254740991}, sha256: {type: string, pattern: ^[0-9a-f]{64}$}, executable: {type: boolean}, target: {type: string, maxLength: 4096}, commit_sha: {type: string, pattern: ^[0-9a-f]{40}$}}}
            }
          }
        },
        type_changed: {
          type: array, maxItems: 1000000, uniqueItems: true,
          items: {
            type: object, additionalProperties: false, required: [],
            properties: {
              before: {type: object, additionalProperties: false, required: [path, type], properties: {path: {type: string, minLength: 1, maxLength: 4096, pattern: ^[^\\x00\\\\]+$}, type: {enum: [file, gitlink, symlink]}, size_bytes: {type: integer, minimum: 0, maximum: 9007199254740991}, sha256: {type: string, pattern: ^[0-9a-f]{64}$}, executable: {type: boolean}, target: {type: string, maxLength: 4096}, commit_sha: {type: string, pattern: ^[0-9a-f]{40}$}}},
              after: {type: object, additionalProperties: false, required: [path, type], properties: {path: {type: string, minLength: 1, maxLength: 4096, pattern: ^[^\\x00\\\\]+$}, type: {enum: [file, gitlink, symlink]}, size_bytes: {type: integer, minimum: 0, maximum: 9007199254740991}, sha256: {type: string, pattern: ^[0-9a-f]{64}$}, executable: {type: boolean}, target: {type: string, maxLength: 4096}, commit_sha: {type: string, pattern: ^[0-9a-f]{40}$}}}
            }
          }
        },
        patch_ref: {$ref: content-ref/v1, x-pullwise-content-schema-id: change-set-patch/v1},
        change_set_digest: {type: string, pattern: ^[0-9a-f]{64}$}
      }
    },
    {
      $schema: https://json-schema.org/draft/2020-12/schema,
      $id: execution-profile/v1,
      type: object,
      additionalProperties: false,
      x-pullwise-digest: {field: profile_digest, domain: pullwise:execution-profile:v1},
      x-pullwise-semantics: [execution_profile],
      required: [schema_id, image_identity, operating_system, sandbox_identity, cpu_architecture, profile_digest],
      properties: {
        schema_id: {const: execution-profile/v1},
        image_identity: {type: string, pattern: ^sha256:[0-9a-f]{64}$},
        operating_system: {const: linux},
        sandbox_identity: {type: string, minLength: 1, maxLength: 160, pattern: ^[A-Za-z0-9][A-Za-z0-9._:/-]*$},
        cpu_architecture: {enum: [aarch64, x86_64]},
        profile_digest: {type: string, pattern: ^[0-9a-f]{64}$}
      }
    },
    {
      $schema: https://json-schema.org/draft/2020-12/schema,
      $id: execution-state-manifest/v1,
      type: object,
      additionalProperties: false,
      x-pullwise-digest: {field: manifest_digest, domain: pullwise:execution-state-manifest:v1},

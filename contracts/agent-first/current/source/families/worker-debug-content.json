{
  "family_id": "worker-debug-content",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "worker-debug-file-manifest/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field":"manifest_digest","domain":"pullwise:worker-debug-file-manifest:v1"},
      "x-pullwise-semantics": {"document_rules":["worker_debug_file_manifest"],"contextual_helpers":[]},
      "required": ["schema_id","entries","entry_count","total_size_bytes","manifest_digest"],
      "properties": {
        "schema_id": {"const":"worker-debug-file-manifest/v1"},
        "entries": {
          "type": "array",
          "minItems": 1,
          "maxItems": 15,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path","sha256","size_bytes","media_type","encoding"],
            "properties": {
              "path": {
                "enum": [
                  "agent-events.jsonl",
                  "agent-task-summary.json",
                  "artifact-manifest.json",
                  "checkpoint-index.json",
                  "codex-events.jsonl",
                  "codex-runtime.json",
                  "debug-summary.json",
                  "error-report.json",
                  "evidence-index.json",
                  "gateway-events.jsonl",
                  "progress.log.jsonl",
                  "qa.json",
                  "redaction-report.json",
                  "task-events.jsonl",
                  "worker.log.jsonl"
                ]
              },
              "sha256": {"type":"string","pattern":"^[0-9a-f]{64}$"},
              "size_bytes": {"type":"integer","minimum":0,"maximum":9007199254740991},
              "media_type": {"enum":["application/json","application/x-ndjson"]},
              "encoding": {"const":"utf-8"}
            }
          }
        },
        "entry_count": {"type":"integer","minimum":1,"maximum":15},
        "total_size_bytes": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "manifest_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "worker-debug-redaction-report/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field":"report_digest","domain":"pullwise:worker-debug-redaction-report:v1"},
      "x-pullwise-semantics": {"document_rules":["worker_debug_redaction_report"],"contextual_helpers":[]},
      "required": ["schema_id","policy_digest","structured_pass_detection_count","archive_rescan_detection_count","redacted_value_count","status","report_digest"],
      "properties": {
        "schema_id": {"const":"worker-debug-redaction-report/v1"},
        "policy_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "structured_pass_detection_count": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "archive_rescan_detection_count": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "redacted_value_count": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "status": {"enum":["clean","redacted"]},
        "report_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"}
      },
      "oneOf": [
        {"type":"object","properties":{"structured_pass_detection_count":{"const":0},"redacted_value_count":{"const":0},"status":{"const":"clean"}}},
        {
          "type": "object",
          "properties": {
            "structured_pass_detection_count": {"type":"integer","minimum":1,"maximum":9007199254740991},
            "redacted_value_count": {"type":"integer","minimum":1,"maximum":9007199254740991},
            "status": {"const":"redacted"}
          }
        }
      ]
    }
  ],

{
  "family_id": "execution-profile",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "execution-profile/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "profile_digest",
        "domain": "pullwise:execution-profile/v1"
      },
      "x-pullwise-semantics": {
        "document_rules": ["execution_profile"],
        "contextual_helpers": []
      },
      "required": [
        "schema_id",
        "image_identity",
        "operating_system",
        "sandbox_identity",
        "cpu_architecture",
        "profile_digest"
      ],
      "properties": {
        "schema_id": {
          "const": "execution-profile/v1"
        },
        "image_identity": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "operating_system": {
          "const": "linux"
        },
        "sandbox_identity": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"
        },
        "cpu_architecture": {
          "enum": [
            "aarch64",
            "x86_64"
          ]
        },
        "profile_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  ],

{
  "family_id": "budget",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "elapsed-budget-ledger/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field":"ledger_digest","domain":"pullwise:elapsed-budget-ledger:v1"},
      "required": [
        "schema_id",
        "task_id",
        "grant_digest",
        "elapsed_limit_ms",
        "consumed_ms",
        "reserved_ms",
        "tool_call_limit",
        "calls_consumed",
        "calls_reserved",
        "ledger_digest"
      ],
      "properties": {
        "schema_id": {"const":"elapsed-budget-ledger/v1"},
        "task_id": {"type":"string","pattern":"^task_[0-9a-f]{32}$"},
        "grant_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "elapsed_limit_ms": {"type":"integer","minimum":1,"maximum":9007199254740991},
        "consumed_ms": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "reserved_ms": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "tool_call_limit": {"type":"integer","minimum":1,"maximum":9007199254740991},
        "calls_consumed": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "calls_reserved": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "ledger_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"}
      },
      "x-pullwise-semantics": {"document_rules":["elapsed_budget_ledger"],"contextual_helpers":["verify_budget_transition"]}
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "elapsed-budget-reservation/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field":"reservation_digest","domain":"pullwise:elapsed-budget-reservation:v1"},
      "required": [
        "schema_id",
        "reservation_id",
        "task_id",
        "attempt_id",
        "invocation_digest",
        "reserved_ms",
        "reserved_calls",
        "previous_consumed_ms",
        "previous_reserved_ms",
        "previous_calls_consumed",
        "previous_calls_reserved",
        "started_at",
        "reservation_digest"
      ],
      "properties": {
        "schema_id": {"const":"elapsed-budget-reservation/v1"},
        "reservation_id": {"type":"string","pattern":"^reserve_[0-9a-f]{32}$"},
        "task_id": {"type":"string","pattern":"^task_[0-9a-f]{32}$"},
        "attempt_id": {"type":"string","pattern":"^attempt_[0-9a-f]{32}$"},
        "invocation_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "reserved_ms": {"type":"integer","minimum":1,"maximum":9007199254740991},
        "reserved_calls": {"const":1},
        "previous_consumed_ms": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "previous_reserved_ms": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "previous_calls_consumed": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "previous_calls_reserved": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "started_at": {"type":"string","pattern":"^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9:.]+Z$"},
        "reservation_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"}
      },
      "x-pullwise-semantics": {
        "document_rules": ["elapsed_budget_reservation"],
        "contextual_helpers": ["verify_budget_transition"]
      }
    },
    {

        "consumed_ms": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "released_ms": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "consumed_calls": {"type":"integer","minimum":0,"maximum":1},
        "released_calls": {"type":"integer","minimum":0,"maximum":1},
        "resulting_consumed_ms": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "resulting_reserved_ms": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "resulting_calls_consumed": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "resulting_calls_reserved": {"type":"integer","minimum":0,"maximum":9007199254740991},
        "outcome": {"enum":["settled","abandoned"]},
        "settlement_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"}
      },
      "x-pullwise-semantics": {
        "document_rules": ["elapsed_budget_settlement"],
        "contextual_helpers": ["verify_budget_transition"]

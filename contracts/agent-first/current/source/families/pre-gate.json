{
  "family_id": "pre-gate",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "pre-gate-evidence-closure-manifest/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field":"manifest_digest","domain":"pullwise:pre-gate-evidence-closure-manifest:v1"},
      "x-pullwise-semantics": {
        "document_rules": ["pre_gate_evidence_closure_manifest"],
        "contextual_helpers": ["verify_pre_gate_evidence_closure_context"]
      },
      "required": [
        "schema_id", "task_id", "pre_gate_root_set_ref", "entries", "entry_count", "pre_gate_closure_digest", "manifest_digest"
      ],
      "properties": {
        "schema_id": {"const":"pre-gate-evidence-closure-manifest/v1"},
        "task_id": {"type":"string","pattern":"^task_[0-9a-f]{32}$"},
        "pre_gate_root_set_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"pre-gate-root-set/v1"},
        "entries": {
          "type": "array", "minItems":6, "maxItems":4096, "uniqueItems":true,
          "items": {
            "$ref": "content-ref/v1",
            "x-pullwise-content-schema-ids": [
              "budget-summary/v1", "canonical-document/v1", "change-set-patch/v1", "change-set/v1", "completion-proposal/v1",
              "debug-redaction-plan/v1", "effect-ledger-snapshot/v1", "effective-execution-policy/v1",
              "execution-profile/v1", "execution-state-manifest/v1", "local-tool-receipt/v1", "observation-manifest/v1", "observation/v1",
              "pre-gate-root-set/v1", "pre-verifier-observation-manifest/v1", "publication-content-manifest/v1", "quality-policy-plan/v1",
              "r0-read-payload/v1", "r0-read-result/v1", "requirement-ledger/v1", "source-content/v1", "source-selection-policy/v1",
              "source-tree-manifest/v1", "stable-error/v1", "task-charter/v1", "task-report/v1", "task-request/v1",
              "terminalization-fact/v1", "verification-attestation-manifest/v1", "verification-attestation/v1", "verifier-input-manifest/v1",
              "verifier-work-report/v1", "waiver-event/v1"
            ]
          }
        },
        "entry_count": {"type":"integer","minimum":6,"maximum":4096},
        "pre_gate_closure_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "manifest_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "pre-gate-root-set/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field":"root_set_digest","domain":"pullwise:pre-gate-root-set:v1"},
      "x-pullwise-semantics": {
        "document_rules": ["pre_gate_root_set"],
        "contextual_helpers": ["verify_pre_gate_root_set_context"]
      },
      "required": [
        "schema_id", "task_id", "outcome_candidate", "request", "policy", "charter", "ledger", "waiver_events", "proposal",
        "original_source", "final_source", "execution_states", "change_set", "pre_observation_manifest", "final_observation_manifest",
        "verifier_inputs", "verifier_work", "attestations", "artifacts", "report", "effect_ledger", "budget_summary",
        "termination_facts", "publication_content_manifest", "debug_redaction_plan", "root_set_digest"
      ],
      "properties": {
        "schema_id": {"const":"pre-gate-root-set/v1"},
        "task_id": {"type":"string","pattern":"^task_[0-9a-f]{32}$"},
        "outcome_candidate": {
          "enum":["BLOCKED","CANCELLED","COMPLETED","COMPLETED_WITH_WAIVERS","FAILED","NO_CHANGE_NEEDED","PARTIAL"]
        },
        "request": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"task-request/v1"},
        "policy": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"effective-execution-policy/v1"},
        "charter": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"task-charter/v1"},
        "ledger": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"requirement-ledger/v1"},
        "waiver_events": {
          "type":"array", "maxItems":256, "uniqueItems":true,
          "items":{"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"waiver-event/v1"}
        },
        "proposal": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"completion-proposal/v1"},
        "original_source": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"source-tree-manifest/v1"},
        "final_source": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"source-tree-manifest/v1"},
        "execution_states": {
          "type":"array", "maxItems":256, "uniqueItems":true,
          "items":{"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"execution-state-manifest/v1"}
        },
        "change_set": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"change-set/v1"},
        "pre_observation_manifest": {
          "$ref":"availability-ref/v1", "x-pullwise-availability-content-schema-id":"pre-verifier-observation-manifest/v1"
        },
        "final_observation_manifest": {
          "$ref":"availability-ref/v1", "x-pullwise-availability-content-schema-id":"observation-manifest/v1"
        },
        "verifier_inputs": {
          "type":"array", "maxItems":256, "uniqueItems":true,
          "items":{"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"verifier-input-manifest/v1"}
        },
        "verifier_work": {
          "type":"array", "maxItems":256, "uniqueItems":true,
          "items":{"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"verifier-work-report/v1"}
        },
        "attestations": {
          "$ref":"availability-ref/v1", "x-pullwise-availability-content-schema-id":"verification-attestation-manifest/v1"
        },
        "artifacts": {
          "type":"array", "maxItems":4096, "uniqueItems":true,
          "items": {
            "$ref": "availability-ref/v1",
            "x-pullwise-availability-content-schema-ids": [
              "change-set-patch/v1", "change-set/v1", "r0-read-result/v1", "source-content/v1", "task-report/v1"
            ]
          }
        },
        "report": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"task-report/v1"},
        "effect_ledger": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"effect-ledger-snapshot/v1"},
        "budget_summary": {"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"budget-summary/v1"},
        "termination_facts": {
          "type":"array", "maxItems":256, "uniqueItems":true,
          "items":{"$ref":"availability-ref/v1","x-pullwise-availability-content-schema-id":"terminalization-fact/v1"}
        },
        "publication_content_manifest": {
          "$ref":"availability-ref/v1", "x-pullwise-availability-content-schema-id":"publication-content-manifest/v1"
        },
        "debug_redaction_plan": {
          "$ref":"availability-ref/v1", "x-pullwise-availability-content-schema-id":"debug-redaction-plan/v1"
        },
        "root_set_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"}
      }
    }
  ],

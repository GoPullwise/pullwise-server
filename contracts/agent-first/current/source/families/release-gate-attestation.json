        "organization_id", "signer_role", "signer_id", "key_id", "signature_algorithm", "signature", "issued_at", "expires_at",
        "attestation_digest"
      ],
      "properties": {
        "schema_id": {"const": "release-gate-attestation/v1"},
        "attestation_id": {"type": "string", "pattern": "^release_attestation_[0-9a-f]{32}$"},
        "package": {"$ref": "current-package-ref/v1"},
        "candidate_build_id": {"type": "string", "pattern": "^candidate_[0-9a-f]{32}$"},
        "candidate_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "release_mode": {"enum": ["BOOTSTRAP", "STABLE"]},
        "stable_package": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "current-package-ref/v1"}
          ]
        },
        "stable_candidate_digest": {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          ]
        },
        "stable_control_plane_digest": {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          ]
        },
        "policy_id": {"type": "string", "pattern": "^release_policy_[0-9a-f]{32}$"},
        "policy_ref": {
          "$ref": "content-ref/v1",
          "x-pullwise-content-schema-id": "release-gate-policy/v1"
        },
        "policy_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "report_id": {"type": "string", "pattern": "^release_report_[0-9a-f]{32}$"},
        "report_ref": {
          "$ref": "content-ref/v1",
          "x-pullwise-content-schema-id": "release-gate-report/v1"
        },
        "report_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "attested_verdict": {"const": "PASS"},
        "attested_exit_code": {"const": 0},
        "organization_id": {"type": "string", "pattern": "^org_[a-z0-9_]{1,64}$"},
        "signer_role": {"const": "release_operator"},
        "signer_id": {"type": "string", "pattern": "^principal_[a-z0-9_]{1,64}$"},
        "key_id": {"type": "string", "pattern": "^key_[A-Za-z0-9_-]{1,96}$"},
        "signature_algorithm": {"const": "Ed25519"},
        "signature": {"type": "string", "pattern": "^[A-Za-z0-9_-]{86}$"},
        "issued_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "expires_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "attestation_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "oneOf": [
        {
          "properties": {
            "release_mode": {"const": "BOOTSTRAP"},
            "stable_package": {"const": null},
            "stable_candidate_digest": {"const": null},
            "stable_control_plane_digest": {"const": null}
          }
        },
        {
          "properties": {
            "release_mode": {"const": "STABLE"},
            "stable_package": {"$ref": "current-package-ref/v1"},
            "stable_candidate_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "stable_control_plane_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          }
        }
      ]

        "receipt_binding_state": {"enum":["bound","not_applicable"]},
        "receipt_digest": {"oneOf":[{"type":"string","pattern":"^[0-9a-f]{64}$"},{"type":"null"}]},
        "accepted_at": {"type":"string","pattern":"^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,9})?Z$"},
        "ack_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"}
      },
      "oneOf": [
        {"type":"object","properties":{"receipt_binding_state":{"const":"bound"},"receipt_digest":{"type":"string"}}},
        {"type":"object","properties":{"receipt_binding_state":{"const":"not_applicable"},"receipt_digest":{"type":"null"}}}
      ]
    },

        "schema_id": "current-package-ref/v1",
        "package_identity": "@pullwise/agent-task-contract",
        "package_version": "0.1.0",
        "content_sha256": "3333333333333333333333333333333333333333333333333333333333333333",
        "root_sha256": "4444444444444444444444444444444444444444444444444444444444444444"
      },
      "expected_code": null
    },
    {
      "fixture_id": "core_idempotency_canonical_document",
      "fixture_class": "idempotency",
      "schema_id": "canonical-document/v1",
      "document": {
        "size_bytes": 42,
        "sha256": "1111111111111111111111111111111111111111111111111111111111111111",
        "canonicalization": "pullwise-canonical-json/v1",
        "content_schema_id": "source-content/v1",
        "schema_id": "canonical-document/v1"
      },
      "expected_code": null

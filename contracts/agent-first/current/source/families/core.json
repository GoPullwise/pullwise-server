    {
      "fixture_id": "core_negative_package_mismatch",
      "fixture_class": "negative",
      "schema_id": "current-package-ref/v1",
      "document": {
        "schema_id": "current-package-ref/v1",
        "package_identity": "@pullwise/agent-task-contract",
        "package_version": "0.1.1",
        "content_sha256": "3333333333333333333333333333333333333333333333333333333333333333",
        "root_sha256": "4444444444444444444444444444444444444444444444444444444444444444"

    {
      "fixture_id": "core_idempotency_canonical_profile",
      "fixture_class": "idempotency",
      "schema_id": "canonical-json-profile/v1",
      "document": {
        "whitespace": "none",
        "number_domain": "safe_integer_only",
        "object_key_order": "ascii_lexicographic",
        "unicode_normalization": "NFC",
        "encoding": "utf-8",
        "profile_id": "pullwise-canonical-json/v1",

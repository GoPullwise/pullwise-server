      "expected_code": "CONTRACT_DOCUMENT_INVALID"
    },
    {
      "fixture_id": "core_negative_canonical_profile_order",
      "fixture_class": "negative",
      "schema_id": "canonical-json-profile/v1",
      "document": {
        "schema_id": "canonical-json-profile/v1",
        "profile_id": "pullwise-canonical-json/v1",
        "encoding": "utf-8",
        "unicode_normalization": "NFC",
        "object_key_order": "insertion",
        "number_domain": "safe_integer_only",
        "whitespace": "none"
      },
      "expected_code": "CONTRACT_DOCUMENT_INVALID"
    },
    {
      "fixture_id": "core_negative_content_ref_artifact_prefix",
      "fixture_class": "negative",
      "schema_id": "content-ref/v1",
      "document": {
        "schema_id": "content-ref/v1",

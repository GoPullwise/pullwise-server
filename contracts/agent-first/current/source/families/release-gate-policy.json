{
  "family_id": "release-gate-policy",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "release-gate-policy/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "policy_digest",
        "domain": "pullwise:release-gate-policy:v1"
      },
      "x-pullwise-semantics": {
        "document_rules": ["release_gate_policy"],
        "contextual_helpers": ["verify_release_gate_policy_context"]
      },
      "required": [
        "schema_id", "policy_id", "package", "candidate_build_id", "candidate_digest", "release_mode",
        "stable_package", "stable_candidate_digest", "stable_control_plane_digest", "benchmark_ref", "benchmark_digest",
        "benchmark_version", "task_inventory_digest", "oracle_rubric_digest", "environment_image_digest",
        "control_plane_digest", "evaluation_runtime_digest", "statistical_implementation_version", "absolute_gates",
        "relative_gates", "profile_budgets", "infrastructure_reason_codes", "canary_stages",
        "canary_platform_failure_rate_max_bps", "canary_relative_platform_failure_increase_max_bps",
        "canary_p95_wall_time_increase_max_bps", "canary_p95_cost_increase_max_bps", "threshold_table_digest",
        "profile_budget_digest", "canary_plan_digest", "signer_role", "signer_id", "key_id", "signature_algorithm",
        "signature", "issued_at", "expires_at", "policy_digest"
      ],
      "properties": {
        "schema_id": {"const": "release-gate-policy/v1"},
        "policy_id": {"type": "string", "pattern": "^release_policy_[0-9a-f]{32}$"},
        "package": {"$ref": "current-package-ref/v1"},
        "candidate_build_id": {"type": "string", "pattern": "^candidate_[0-9a-f]{32}$"},
        "candidate_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "release_mode": {"enum": ["BOOTSTRAP", "STABLE"]},
        "stable_package": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "current-package-ref/v1"}
          ]
        },
        "stable_candidate_digest": {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          ]
        },
        "stable_control_plane_digest": {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          ]
        },
        "benchmark_ref": {
          "$ref": "content-ref/v1",
          "x-pullwise-content-schema-id": "benchmark-bundle/v1"
        },
        "benchmark_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "benchmark_version": {"type": "string", "pattern": "^benchmark-[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "task_inventory_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "oracle_rubric_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "environment_image_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "control_plane_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "evaluation_runtime_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "statistical_implementation_version": {"const": "pullwise-release-statistics/v1"},
        "absolute_gates": {
          "type": "array", "minItems": 1, "maxItems": 64, "uniqueItems": true,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["gate_id", "comparator", "threshold", "unit", "waiver_allowed"],
            "properties": {
              "gate_id": {"type": "string", "pattern": "^absolute_[a-z0-9_]{1,96}$"},
              "comparator": {"enum": ["EQ", "GTE", "LT", "LTE"]},
              "threshold": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
              "unit": {"enum": ["BPS", "COUNT"]},
              "waiver_allowed": {"type": "boolean"}
            }
          }
        },
        "relative_gates": {
          "type": "array", "minItems": 1, "maxItems": 64, "uniqueItems": true,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["gate_id", "applicability", "max_regression_bps"],
            "properties": {
              "gate_id": {"type": "string", "pattern": "^relative_[a-z0-9_]{1,96}$"},
              "applicability": {"enum": ["NOT_APPLICABLE", "REQUIRED"]},
              "max_regression_bps": {"type": "integer", "minimum": 0, "maximum": 10000}
            }
          }
        },
        "profile_budgets": {
          "type": "array", "minItems": 1, "maxItems": 64, "uniqueItems": true,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["profile_id", "wall_ms", "token_limit", "cost_microusd"],
            "properties": {
              "profile_id": {"type": "string", "pattern": "^profile_[a-z0-9_]{1,64}$"},
              "wall_ms": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
              "token_limit": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
              "cost_microusd": {"type": "integer", "minimum": 1, "maximum": 9007199254740991}
            }
          }
        },
        "infrastructure_reason_codes": {
          "type": "array", "minItems": 1, "maxItems": 64, "uniqueItems": true,
          "items": {"type": "string", "pattern": "^INFRA_[A-Z0-9_]{1,64}$"}
        },
        "canary_stages": {
          "type": "array", "minItems": 3, "maxItems": 3, "uniqueItems": true,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["stage_id", "target_capacity_bps", "minimum_window_ms", "minimum_accepted_tasks"],
            "properties": {
              "stage_id": {"enum": ["CAPACITY_5", "CAPACITY_25", "FULL_CAPACITY"]},
              "target_capacity_bps": {"type": "integer", "minimum": 1, "maximum": 10000},
              "minimum_window_ms": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
              "minimum_accepted_tasks": {"type": "integer", "minimum": 0, "maximum": 9007199254740991}
            }
          }
        },
        "canary_platform_failure_rate_max_bps": {"const": 200},
        "canary_relative_platform_failure_increase_max_bps": {"const": 200},
        "canary_p95_wall_time_increase_max_bps": {"const": 2000},
        "canary_p95_cost_increase_max_bps": {"const": 2000},
        "threshold_table_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "profile_budget_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "canary_plan_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "signer_role": {"const": "release_operator"},
        "signer_id": {"type": "string", "pattern": "^principal_[a-z0-9_]{1,64}$"},
        "key_id": {"type": "string", "pattern": "^key_[A-Za-z0-9_-]{1,96}$"},
        "signature_algorithm": {"const": "Ed25519"},
        "signature": {"type": "string", "minLength": 2, "maxLength": 128, "pattern": "^[A-Za-z0-9_-]+$"},
        "issued_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "expires_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "policy_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "oneOf": [
        {
          "properties": {
            "release_mode": {"const": "BOOTSTRAP"},
            "stable_package": {"const": null},
            "stable_candidate_digest": {"const": null},
            "stable_control_plane_digest": {"const": null}
          }
        },
        {
          "properties": {
            "release_mode": {"const": "STABLE"},
            "stable_package": {"$ref": "current-package-ref/v1"},
            "stable_candidate_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "stable_control_plane_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          }
        }
      ]
    }

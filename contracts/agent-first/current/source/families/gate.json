{
  "family_id": "gate",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "gate-decision/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field": "decision_digest", "domain": "pullwise:gate-decision:v1"},
      "x-pullwise-semantics": {"document_rules":["gate_decision"],
        "contextual_helpers":["evaluate_success_gate","evaluate_terminalization_gate"]},
      "required": [
        "schema_id", "decision_kind", "input_snapshot_ref", "input_digest", "predicate_registry_digest", "passed",
        "predicate_results", "decision_digest"
      ],
      "properties": {
        "schema_id": {"const": "gate-decision/v1"},
        "decision_kind": {"enum": ["success", "terminalization"]},
        "input_snapshot_ref": {
          "$ref": "content-ref/v1",
          "x-pullwise-content-schema-ids": ["gate-input-snapshot/v1", "terminalization-input-snapshot/v1"]
        },
        "input_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "predicate_registry_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "requested_outcome": {"enum": ["COMPLETED", "COMPLETED_WITH_WAIVERS", "NO_CHANGE_NEEDED"]},
        "selected_outcome": {"enum": ["BLOCKED", "CANCELLED", "FAILED", "PARTIAL"]},
        "selected_reason": {
          "enum": [
            "APPROVAL_REQUIRED", "BUDGET_EXHAUSTED", "CAPABILITY_UNAVAILABLE", "CONTRACT_INVALID", "DEADLINE_REACHED",
            "ENVIRONMENT_UNAVAILABLE", "INPUT_REQUIRED", "INTERACTION_UNAVAILABLE", "LEASE_CANCELLED",
            "POLICY_INVARIANT_BROKEN", "POLICY_UNSUPPORTED", "PROTOCOL_FAILURE", "QUALITY_GATE_FAILED",
            "RUNTIME_FAILURE", "SAFE_PARTIAL_DELIVERY", "SERVER_CANCELLED", "SOURCE_MUTATION_FORBIDDEN",
            "STORAGE_FAILURE", "USER_CANCELLED", "VERIFICATION_INCOMPLETE"
          ]
        },
        "authoritative_fact_refs": {
          "type": "array", "minItems": 1, "maxItems": 256, "uniqueItems": true,
          "items": {"$ref": "content-ref/v1", "x-pullwise-content-schema-id": "terminalization-fact/v1"}
        },
        "source_availability": {
          "$ref": "availability-ref/v1", "x-pullwise-availability-content-schema-id": "source-tree-manifest/v1"
        },
        "evidence_availability": {
          "$ref": "availability-ref/v1",
          "x-pullwise-availability-content-schema-id": "pre-gate-evidence-closure-manifest/v1"
        },
        "effect_availability": {
          "$ref": "availability-ref/v1", "x-pullwise-availability-content-schema-id": "effect-ledger-snapshot/v1"
        },
        "passed": {"type": "boolean"},
        "predicate_results": {
          "type": "array",
          "minItems": 5,
          "maxItems": 15,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["predicate_id", "passed", "failure_code", "repairable", "evidence_refs"],
            "properties": {
              "predicate_id": {
                "enum": [
                  "GATE_TASK_STATE", "GATE_LEASE_VALID", "GATE_DEADLINE", "GATE_POLICY", "GATE_LEDGER",
                  "GATE_SOURCE_FROZEN", "GATE_PROPOSAL_FRESH", "GATE_QUALITY_PLAN", "GATE_ATTESTATIONS",
                  "GATE_REQUIREMENTS", "GATE_OUTCOME_SHAPE", "GATE_EFFECTS_EMPTY", "GATE_EVIDENCE_CLOSURE",
                  "GATE_BUDGET", "GATE_SECRET_SCAN", "GATE_TERMINAL_AUTHORITY_FACT", "GATE_TERMINAL_AVAILABILITY",
                  "GATE_TERMINAL_NO_ACTIVE_EFFECTS", "GATE_TERMINAL_OUTCOME_CLASSIFICATION",
                  "GATE_TERMINAL_ARTIFACT_DELIVERY"
                ]
              },
              "passed": {"type": "boolean"},
              "failure_code": {
                "type": ["string", "null"],
                "enum": [
                  null, "ABSOLUTE_DEADLINE_EXCEEDED", "ATTESTATION_NOT_INDEPENDENT", "BUDGET_EXHAUSTED",
                  "CAS_CORRUPT", "CONTRACT_DOCUMENT_INVALID", "DEBUG_REDACTION_FAILED", "DEBUG_UPLOAD_FAILED",
                  "EVENT_DELIVERY_UNKNOWN", "EVIDENCE_CLOSURE_INVALID", "EXECUTION_STATE_UNAVAILABLE",
                  "GATE_INPUT_STALE", "LEASE_INVALID", "MANDATORY_REQUIREMENT_FAILED",
                  "MANDATORY_REQUIREMENT_UNVERIFIABLE", "NATIVE_EPOCH_STALE", "OBSERVATION_ACTOR_MISMATCH",
                  "OBSERVATION_MISSING", "OWNER_EPOCH_STALE", "POLICY_INVARIANT_BROKEN", "POLICY_UNSUPPORTED",
                  "PROTOCOL_FAILURE", "REQUIREMENT_ID_COLLISION", "ROLE_NOT_ENABLED", "SOURCE_STATE_CHANGED",
                  "SOURCE_STATE_MISMATCH", "STATE_TRANSITION_INVALID", "TASK_VERSION_STALE",
                  "TERMINALIZATION_RESERVE_REACHED", "WAIVER_INVALID"
                ]
              },
              "repairable": {"type": "boolean"},
              "evidence_refs": {
                "type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true,
                "items": {
                  "$ref": "content-ref/v1",
                  "x-pullwise-content-schema-ids": [
                    "attempt-record/v1", "budget-summary/v1", "completion-proposal/v1", "debug-redaction-plan/v1",
                    "effect-ledger-snapshot/v1", "effective-execution-policy/v1", "gate-input-snapshot/v1",
                    "observation-manifest/v1", "pre-gate-evidence-closure-manifest/v1", "pre-gate-root-set/v1",
                    "publication-content-manifest/v1", "quality-policy-plan/v1", "requirement-ledger/v1",
                    "source-tree-manifest/v1", "task-record/v1", "terminalization-fact/v1",
                    "terminalization-input-snapshot/v1", "verification-attestation-manifest/v1"
                  ]
                }
              }
            }
          }
        },
        "decision_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": [
            "schema_id", "decision_kind", "input_snapshot_ref", "input_digest", "predicate_registry_digest",
            "requested_outcome", "passed", "predicate_results", "decision_digest"
          ],
          "properties": {
            "schema_id": {},
            "decision_kind": {"const": "success"},
            "input_snapshot_ref": {
              "$ref": "content-ref/v1", "x-pullwise-content-schema-id": "gate-input-snapshot/v1"
            },
            "input_digest": {}, "predicate_registry_digest": {}, "requested_outcome": {}, "passed": {},
            "predicate_results": {
              "type": "array", "minItems": 15, "maxItems": 15,
              "items": {
                "type": "object",
                "properties": {
                  "predicate_id": {
                    "enum": [
                      "GATE_TASK_STATE", "GATE_LEASE_VALID", "GATE_DEADLINE", "GATE_POLICY", "GATE_LEDGER",
                      "GATE_SOURCE_FROZEN", "GATE_PROPOSAL_FRESH", "GATE_QUALITY_PLAN", "GATE_ATTESTATIONS",
                      "GATE_REQUIREMENTS", "GATE_OUTCOME_SHAPE", "GATE_EFFECTS_EMPTY", "GATE_EVIDENCE_CLOSURE",
                      "GATE_BUDGET", "GATE_SECRET_SCAN"
                    ]
                  }
                }
              }
            },
            "decision_digest": {}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": [
            "schema_id", "decision_kind", "input_snapshot_ref", "input_digest", "predicate_registry_digest",
            "selected_outcome", "selected_reason", "authoritative_fact_refs", "source_availability",
            "evidence_availability", "effect_availability", "passed", "predicate_results", "decision_digest"
          ],
          "properties": {
            "schema_id": {},
            "decision_kind": {"const": "terminalization"},
            "input_snapshot_ref": {
              "$ref": "content-ref/v1", "x-pullwise-content-schema-id": "terminalization-input-snapshot/v1"
            },
            "input_digest": {}, "predicate_registry_digest": {}, "selected_outcome": {}, "selected_reason": {},
            "authoritative_fact_refs": {}, "source_availability": {}, "evidence_availability": {},
            "effect_availability": {}, "passed": {},
            "predicate_results": {
              "type": "array", "minItems": 5, "maxItems": 5,
              "items": {
                "type": "object",
                "properties": {
                  "predicate_id": {
                    "enum": [
                      "GATE_TERMINAL_AUTHORITY_FACT", "GATE_TERMINAL_AVAILABILITY",
                      "GATE_TERMINAL_NO_ACTIVE_EFFECTS", "GATE_TERMINAL_OUTCOME_CLASSIFICATION",
                      "GATE_TERMINAL_ARTIFACT_DELIVERY"
                    ]
                  }
                }
              }
            },
            "decision_digest": {}
          },
          "oneOf": [
            {"type": "object",
              "properties": {
                "selected_outcome": {"const": "PARTIAL"},
                "selected_reason": {"enum": ["BUDGET_EXHAUSTED", "CAPABILITY_UNAVAILABLE", "DEADLINE_REACHED",
                  "INTERACTION_UNAVAILABLE", "SAFE_PARTIAL_DELIVERY", "VERIFICATION_INCOMPLETE"]}
              }
            },
            {"type": "object",
              "properties": {
                "selected_outcome": {"const": "BLOCKED"},
                "selected_reason": {"enum": ["APPROVAL_REQUIRED", "CAPABILITY_UNAVAILABLE", "ENVIRONMENT_UNAVAILABLE",
                  "INPUT_REQUIRED", "INTERACTION_UNAVAILABLE", "POLICY_INVARIANT_BROKEN", "POLICY_UNSUPPORTED"]}
              }
            },
            {"type": "object",
              "properties": {
                "selected_outcome": {"const": "FAILED"},
                "selected_reason": {"enum": ["BUDGET_EXHAUSTED", "CONTRACT_INVALID", "DEADLINE_REACHED",
                  "POLICY_INVARIANT_BROKEN", "POLICY_UNSUPPORTED", "PROTOCOL_FAILURE", "QUALITY_GATE_FAILED",
                  "RUNTIME_FAILURE", "SOURCE_MUTATION_FORBIDDEN", "STORAGE_FAILURE"]}
              }

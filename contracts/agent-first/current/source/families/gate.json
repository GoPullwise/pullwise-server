                  ]
                }
              }
            },
            {
              "type": "object",
              "properties": {
                "selected_outcome": {"const": "BLOCKED"},
                "selected_reason": {
                  "enum": [
                    "APPROVAL_REQUIRED", "CAPABILITY_UNAVAILABLE", "ENVIRONMENT_UNAVAILABLE", "INPUT_REQUIRED",
                    "INTERACTION_UNAVAILABLE", "POLICY_INVARIANT_BROKEN", "POLICY_UNSUPPORTED"
                  ]
                }
              }

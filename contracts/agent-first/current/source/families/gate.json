            "input_digest": {}, "predicate_registry_digest": {}, "selected_outcome": {}, "selected_reason": {},
            "authoritative_fact_refs": {}, "source_availability": {}, "evidence_availability": {},
            "effect_availability": {}, "passed": {},
            "predicate_results": {
              "type": "array", "minItems": 5, "maxItems": 5,

              "properties": {
                "selected_outcome": {"const": "CANCELLED"},
                "selected_reason": {"enum": ["LEASE_CANCELLED", "SERVER_CANCELLED", "USER_CANCELLED"]}
              }
            }
          ]
        }
      ]

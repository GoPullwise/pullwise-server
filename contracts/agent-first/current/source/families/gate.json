{
  "family_id": "gate",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "gate-decision/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field": "decision_digest", "domain": "pullwise:gate-decision:v1"},
      "required": ["schema_id", "input_digest", "predicate_registry_digest", "requested_outcome", "passed", "predicate_results", "decision_digest"],
      "properties": {
        "schema_id": {"const": "gate-decision/v1"},
        "input_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "predicate_registry_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "requested_outcome": {"enum": ["COMPLETED", "NO_CHANGE_NEEDED", "PARTIAL", "BLOCKED", "FAILED", "CANCELLED"]},
        "passed": {"type": "boolean"},
        "predicate_results": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["predicate_id", "passed", "failure_code", "repairable", "evidence_refs"],
            "properties": {
              "predicate_id": {"enum": ["GATE_BUDGET_SETTLED", "GATE_EVIDENCE_COMPLETE", "GATE_POLICY_SATISFIED", "GATE_SOURCE_STABLE"]},
              "passed": {"type": "boolean"},
              "failure_code": {"type": ["string", "null"], "pattern": "^[A-Z][A-Z0-9_]{2,95}$"},
              "repairable": {"type": "boolean"},
              "evidence_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "content-ref/v1"}}
            }
          }
        },
        "decision_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "gate-predicate-registry/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field": "registry_digest", "domain": "pullwise:gate-predicate-registry:v1"},
      "x-pullwise-semantics": {
        "document_rules": ["gate_predicate_registry"],
        "contextual_helpers": []
      },
      "required": ["schema_id", "predicates", "registry_digest"],
      "properties": {
        "schema_id": {"const": "gate-predicate-registry/v1"},
        "predicates": {
          "type": "array",
          "minItems": 20,
          "maxItems": 20,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["predicate_id", "decision_kind", "input_schema_ids", "failure_codes"],
            "properties": {
              "predicate_id": {
                "enum": [
                  "GATE_TASK_STATE", "GATE_LEASE_VALID", "GATE_DEADLINE", "GATE_POLICY", "GATE_LEDGER",
                  "GATE_SOURCE_FROZEN", "GATE_PROPOSAL_FRESH", "GATE_QUALITY_PLAN", "GATE_ATTESTATIONS",
                  "GATE_REQUIREMENTS", "GATE_OUTCOME_SHAPE", "GATE_EFFECTS_EMPTY", "GATE_EVIDENCE_CLOSURE",
                  "GATE_BUDGET", "GATE_SECRET_SCAN", "GATE_TERMINAL_AUTHORITY_FACT", "GATE_TERMINAL_AVAILABILITY",
                  "GATE_TERMINAL_NO_ACTIVE_EFFECTS", "GATE_TERMINAL_OUTCOME_CLASSIFICATION",
                  "GATE_TERMINAL_ARTIFACT_DELIVERY"
                ]
              },
              "decision_kind": {"enum": ["success", "terminalization"]},
              "input_schema_ids": {
                "type": "array", "minItems": 1, "uniqueItems": true,
                "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*/v[1-9][0-9]*$"}
              },
              "failure_codes": {
                "type": "array", "minItems": 1, "uniqueItems": true,
                "items": {
                  "enum": [
                    "ABSOLUTE_DEADLINE_EXCEEDED", "ATTESTATION_NOT_INDEPENDENT", "BUDGET_EXHAUSTED", "CAS_CORRUPT",
                    "CONTRACT_DOCUMENT_INVALID", "DEBUG_REDACTION_FAILED", "DEBUG_UPLOAD_FAILED",
                    "EVIDENCE_CLOSURE_INVALID", "EVENT_DELIVERY_UNKNOWN", "EXECUTION_STATE_UNAVAILABLE",
                    "GATE_INPUT_STALE", "LEASE_INVALID", "MANDATORY_REQUIREMENT_FAILED",
                    "MANDATORY_REQUIREMENT_UNVERIFIABLE", "NATIVE_EPOCH_STALE", "OBSERVATION_ACTOR_MISMATCH",
                    "OBSERVATION_MISSING", "OWNER_EPOCH_STALE", "POLICY_INVARIANT_BROKEN", "POLICY_UNSUPPORTED",
                    "PROTOCOL_FAILURE", "REQUIREMENT_ID_COLLISION", "ROLE_NOT_ENABLED", "SOURCE_STATE_CHANGED",
                    "SOURCE_STATE_MISMATCH", "STATE_TRANSITION_INVALID", "TASK_VERSION_STALE",
                    "TERMINALIZATION_RESERVE_REACHED", "WAIVER_INVALID"
                  ]
                }
              }
            }
          }
        },
        "registry_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  ],
  "fixtures": [

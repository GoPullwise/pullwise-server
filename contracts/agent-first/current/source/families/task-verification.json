{
  "family_id": "task-verification",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "verification-attestation-manifest/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field":"manifest_digest","domain":"pullwise:verification-attestation-manifest:v1"},
      "x-pullwise-semantics": {
        "document_rules": ["verification_attestation_manifest"],
        "contextual_helpers": ["verify_attestation_manifest_context"]
      },
      "required": [
        "schema_id",
        "manifest_id",
        "task_id",
        "proposal_id",
        "quality_policy_plan_ref",
        "quality_policy_plan_digest",
        "final_observation_manifest_ref",
        "final_observation_manifest_digest",
        "attestations",
        "attestation_count",
        "requirement_aggregates",
        "created_at",
        "manifest_digest"
      ],
      "properties": {
        "schema_id": {"const":"verification-attestation-manifest/v1"},
        "manifest_id": {"type":"string","pattern":"^vmanifest_[0-9a-f]{32}$"},
        "task_id": {"type":"string","pattern":"^task_[0-9a-f]{32}$"},
        "proposal_id": {"type":"string","pattern":"^proposal_[0-9a-f]{32}$"},
        "quality_policy_plan_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"quality-policy-plan/v1"},
        "quality_policy_plan_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "final_observation_manifest_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"observation-manifest/v1"},
        "final_observation_manifest_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "attestations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["attestation_id","slot_id","attestation_ref","run_status"],
            "properties": {
              "attestation_id": {"type":"string","pattern":"^attest_[0-9a-f]{32}$"},
              "slot_id": {"type":"string","pattern":"^slot_[0-9a-f]{32}$"},
              "attestation_ref": {"$ref":"content-ref/v1","x-pullwise-content-schema-id":"verification-attestation/v1"},
              "run_status": {"enum":["NEEDS_WORK","PASS","POLICY_VIOLATION","UNVERIFIABLE"]}
            }
          }
        },
        "attestation_count": {"type":"integer","minimum":1,"maximum":256},
        "requirement_aggregates": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["requirement_id","required_slot_ids","attestation_ids","verdict"],
            "properties": {
              "requirement_id": {
                "type": "string",
                "pattern": "^req_(?:user_objective|user_acceptance|user_constraint|delivery|policy|interaction|derived)_[0-9a-f]{64}$"
              },
              "required_slot_ids": {
                "type": "array",
                "minItems": 1,
                "maxItems": 256,
                "uniqueItems": true,
                "items": {"type":"string","pattern":"^slot_[0-9a-f]{32}$"}
              },
              "attestation_ids": {
                "type": "array",
                "minItems": 0,
                "maxItems": 256,
                "uniqueItems": true,
                "items": {"type":"string","pattern":"^attest_[0-9a-f]{32}$"}
              },
              "verdict": {"enum":["FAIL","PASS","UNVERIFIABLE"]}
            }
          }
        },
        "created_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "manifest_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"}
      }
    }
  ],

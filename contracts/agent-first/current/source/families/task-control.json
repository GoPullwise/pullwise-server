{
  "family_id": "task-control",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "attempt-record/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-semantics": {
        "document_rules": ["attempt_state_nullability", "attempt_transport_binding_all_or_none", "fenced_reason_ownership_loss"],
        "contextual_helpers": ["validate_attempt_transition", "validate_claim_write_set"]
      },
      "required": [
        "schema_id", "attempt_id", "task_id", "native_epoch", "transport_binding",
        "state", "state_version", "predecessor_checkpoint_generation",
        "owner_session_id", "lease_acquired_at", "started_at", "ended_at",
        "termination_reason", "budget_reservation_id"
      ],
      "properties": {
        "schema_id": {"const": "attempt-record/v1"},
        "attempt_id": {"type": "string", "pattern": "^attempt_[0-9a-f]{32}$"},
        "task_id": {"type": "string", "pattern": "^task_[0-9a-f]{32}$"},
        "native_epoch": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "transport_binding": {
          "type": "object",
          "additionalProperties": false,
          "required": ["protocol_mode", "outer_job_id", "run_id", "lease_id", "transport_epoch"],
          "properties": {
            "protocol_mode": {"const": "agent_task_v1"},
            "outer_job_id": {"type": ["string", "null"], "minLength": 1, "maxLength": 160},
            "run_id": {"type": ["string", "null"], "minLength": 1, "maxLength": 160},
            "lease_id": {"type": ["string", "null"], "minLength": 1, "maxLength": 160},
            "transport_epoch": {"type": ["integer", "null"], "minimum": 1, "maximum": 9007199254740991}
          },
          "oneOf": [
            {"properties": {"outer_job_id": {"type": "string"}, "run_id": {"type": "string"}, "lease_id": {"type": "string"}, "transport_epoch": {"type": "integer"}}},
            {"properties": {"outer_job_id": {"const": null}, "run_id": {"const": null}, "lease_id": {"const": null}, "transport_epoch": {"const": null}}}
          ]
        },
        "state": {"enum": ["CREATED", "LEASED", "PREPARING", "RUNNING", "VERIFYING", "SUSPENDING", "PUBLISHING", "SUCCEEDED", "SUSPENDED", "FAILED", "CANCELLED", "FENCED"]},
        "state_version": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "predecessor_checkpoint_generation": {"type": ["integer", "null"], "minimum": 0, "maximum": 9007199254740991},
        "owner_session_id": {"type": "string", "pattern": "^sess_[0-9a-f]{32}$"},
        "lease_acquired_at": {"type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"},
        "started_at": {"type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"},
        "ended_at": {"type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"},
        "termination_reason": {"type": ["string", "null"], "pattern": "^[A-Z][A-Z0-9_]{0,127}$"},
        "budget_reservation_id": {"type": ["string", "null"], "pattern": "^reserve_[0-9a-f]{32}$"}
      },
      "oneOf": [
        {"properties": {"state": {"enum": ["CREATED", "LEASED", "PREPARING", "RUNNING", "VERIFYING", "SUSPENDING", "PUBLISHING"]}, "ended_at": {"const": null}, "termination_reason": {"const": null}}},
        {"properties": {"state": {"enum": ["SUCCEEDED", "SUSPENDED", "FAILED", "CANCELLED"]}, "ended_at": {"type": "string"}, "termination_reason": {"type": "string"}}},
        {"properties": {"state": {"const": "FENCED"}, "ended_at": {"type": "string"}, "termination_reason": {"const": "OWNERSHIP_LOST"}}}
      ]
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "effective-execution-policy/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "digest",
        "domain": "pullwise:effective-execution-policy/v1"
      },
      "x-pullwise-semantics": {
        "document_rules": [
          "budget_ceiling_consistency",
          "capability_sets_disjoint_sorted_unique",
          "policy_digest_exact",
          "risk_ceiling_current_mvp",
          "root_and_origin_sets_sorted_unique",
          "utf8_nfc_byte_limits"
        ],
        "contextual_helpers": ["validate_effective_policy_derivation"]
      },
      "required": [
        "schema_id", "policy_id", "policy_version", "issued_at", "issuer",
        "task_type", "granted_capabilities", "denied_capabilities",
        "capability_risk_ceiling", "quality_risk_floor", "source_write_mode",
        "allowed_read_roots", "allowed_write_roots", "agent_tool_network",
        "dependency_install", "command_policy_ref", "secret_policy_ref",
        "redaction_policy_ref", "budgets", "terminalization_reserve_ms",
        "max_agents", "max_agent_sessions_total", "max_attempts",
        "interaction_mode", "authorized_waiver_issuers", "digest"
      ],
      "properties": {
        "schema_id": {"const": "effective-execution-policy/v1"},
        "policy_id": {"type": "string", "pattern": "^policy_[0-9a-f]{32}$"},
        "policy_version": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "issued_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"},
        "issuer": {"$ref": "actor/v1"},
        "task_type": {"type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*/v[1-9][0-9]*$"},
        "granted_capabilities": {
          "type": "array", "maxItems": 256, "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
          }
        },
        "denied_capabilities": {
          "type": "array", "maxItems": 256,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "reason_code"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
              },
              "reason_code": {
                "type": "string", "pattern": "^[A-Z][A-Z0-9_]{0,127}$"
              }
            }
          }
        },
        "capability_risk_ceiling": {"enum": ["R0", "R1"]},
        "quality_risk_floor": {"enum": ["Q0", "Q1", "Q2", "Q3"]},
        "source_write_mode": {"enum": ["isolated_reversible", "read_only"]},
        "allowed_read_roots": {
          "type": "array", "maxItems": 256, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 4096}
        },
        "allowed_write_roots": {
          "type": "array", "maxItems": 256, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 4096}
        },
        "agent_tool_network": {
          "type": "object", "additionalProperties": false,
          "required": ["mode", "origins"],
          "properties": {
            "mode": {"enum": ["deny", "allowlist"]},
            "origins": {
              "type": "array", "maxItems": 256, "uniqueItems": true,
              "items": {
                "type": "string", "minLength": 1, "maxLength": 2048,
                "pattern": "^[\\x20-\\x7e]+$"
              }
            }
          }
        },
        "dependency_install": {"enum": ["deny", "approval_required"]},
        "command_policy_ref": {"$ref": "content-ref/v1"},
        "secret_policy_ref": {"$ref": "content-ref/v1"},
        "redaction_policy_ref": {"$ref": "content-ref/v1"},
        "budgets": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "wall_ms", "token_input", "token_output", "cost_micros",
            "tool_calls", "agent_sessions", "attempts", "output_bytes"
          ],
          "properties": {
            "wall_ms": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
            "token_input": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
            "token_output": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
            "cost_micros": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
            "tool_calls": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
            "agent_sessions": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
            "attempts": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
            "output_bytes": {"type": "integer", "minimum": 0, "maximum": 9007199254740991}
          }
        },
        "terminalization_reserve_ms": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
        "max_agents": {"type": "integer", "minimum": 1, "maximum": 256},
        "max_agent_sessions_total": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "max_attempts": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "interaction_mode": {"enum": ["supported", "unavailable"]},
        "authorized_waiver_issuers": {
          "type": "array", "maxItems": 256, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 160}
        },
        "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },

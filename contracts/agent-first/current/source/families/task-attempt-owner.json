          "pattern": "^task_[0-9a-f]{32}$"
        },
        "owner_id": {
          "type": "string",
          "pattern": "^owner_[0-9a-f]{32}$"
        },
        "owner_epoch": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "session_id": {
          "type": "string",
          "pattern": "^sess_[0-9a-f]{32}$"
        },
        "attempt_id": {
          "type": "string",
          "pattern": "^attempt_[0-9a-f]{32}$"
        },
        "native_epoch": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "state": {
          "enum": [
            "STARTING",
            "ACTIVE",
            "CLOSED",
            "FENCED"
          ]
        },
        "state_version": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "started_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "ended_at": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "termination_reason": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Z][A-Z0-9_]{0,127}$"
        }
      },
      "oneOf": [
        {
          "properties": {
            "state": {
              "enum": [
                "STARTING",
                "ACTIVE"
              ]
            },
            "ended_at": {
              "const": null
            },
            "termination_reason": {
              "const": null
            }
          }
        },
        {
          "properties": {
            "state": {
              "const": "CLOSED"
            },
            "ended_at": {
              "type": "string"
            },
            "termination_reason": {
              "type": "string"
            }
          }
        },
        {
          "properties": {
            "state": {
              "const": "FENCED"
            },
            "ended_at": {
              "type": "string"
            },
            "termination_reason": {
              "const": "OWNERSHIP_LOST"
            }
          }
        }
      ]
    }
  ],

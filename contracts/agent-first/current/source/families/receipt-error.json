{
  "family_id": "receipt-error",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "dispatch-abandonment/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field": "abandonment_digest", "domain": "pullwise:dispatch-abandonment:v1"},
      "required": ["schema_id", "package", "intent_id", "invocation_digest", "reservation_id", "reason", "budget_settlement_digest", "abandoned_at", "abandonment_digest"],
      "properties": {
        "schema_id": {"const": "dispatch-abandonment/v1"},
        "package": {"$ref": "current-package-ref/v1"},
        "intent_id": {"type": "string", "pattern": "^intent_[0-9a-f]{32}$"},
        "invocation_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "reservation_id": {"type": "string", "pattern": "^reserve_[0-9a-f]{32}$"},
        "reason": {"enum": ["authority_lost", "dispatch_not_started", "worker_shutdown", "recovery_timeout"]},
        "budget_settlement_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "abandoned_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9:.]+Z$"},
        "abandonment_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "error-response/v1",
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "error"],
      "properties": {
        "schema_id": {"const": "error-response/v1"},
        "error": {"$ref": "stable-error/v1"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "server-transport-receipt-binding/v1",
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "receipt_id", "receipt_digest", "state", "bound_transport_envelope_digest"],
      "properties": {
        "schema_id": {"const": "server-transport-receipt-binding/v1"},
        "receipt_id": {"type": "string", "pattern": "^receipt_[0-9a-f]{32}$"},
        "receipt_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "state": {"enum": ["unbound", "bound"]},
        "bound_transport_envelope_digest": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "server-transport-receipt/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field": "receipt_digest", "domain": "pullwise:server-transport-receipt:v1"},
      "required": ["schema_id", "receipt_kind", "package", "receipt_id", "task_id", "attempt_id", "session_id", "grant_digest", "task_version", "deletion_version", "owner_epoch", "native_epoch", "transport_epoch", "content_ref", "accepted_at", "receipt_digest"],
      "properties": {
        "schema_id": {"const": "server-transport-receipt/v1"},
        "receipt_kind": {"const": "server_transport"},
        "package": {"$ref": "current-package-ref/v1"},
        "receipt_id": {"type": "string", "pattern": "^receipt_[0-9a-f]{32}$"},
        "task_id": {"type": "string", "pattern": "^task_[0-9a-f]{32}$"},
        "attempt_id": {"type": "string", "pattern": "^attempt_[0-9a-f]{32}$"},
        "session_id": {"type": "string", "pattern": "^sess_[0-9a-f]{32}$"},
        "grant_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "task_version": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "deletion_version": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
        "owner_epoch": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "native_epoch": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "transport_epoch": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "content_ref": {"$ref": "content-ref/v1"},
        "accepted_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9:.]+Z$"},
        "receipt_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "stable-error/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field": "error_digest", "domain": "pullwise:stable-error:v1"},
      "required": ["schema_id", "code", "message", "retryable", "retry_scope", "request_id", "details", "error_digest"],
      "properties": {
        "schema_id": {"const": "stable-error/v1"},
        "code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,95}$"},
        "message": {"type": "string", "minLength": 1, "maxLength": 512},
        "retryable": {"type": "boolean"},
        "retry_scope": {"enum": ["none", "same_invocation", "new_claim", "operator"]},
        "request_id": {"type": "string", "pattern": "^req_[0-9a-f]{32}$"},
        "details": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "task_id": {"type": "string", "pattern": "^task_[0-9a-f]{32}$"},
            "attempt_id": {"type": "string", "pattern": "^attempt_[0-9a-f]{32}$"},
            "invocation_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "expected_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "actual_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "stable_reason": {"type": "string", "minLength": 1, "maxLength": 160}
          }
        },
        "error_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  ],
  "fixtures": [
    {
      "fixture_id": "receipt_crash_binding_rollback",
      "fixture_class": "crash",
      "schema_id": "server-transport-receipt-binding/v1",
      "document": {"crash_point": "after_binding_cas_before_commit", "expected_state": "unbound"},
      "expected_code": "TRANSPORT_BINDING_ROLLED_BACK"
    },
    {
      "fixture_id": "receipt_golden_immutable_transport",
      "fixture_class": "golden",
      "schema_id": "server-transport-receipt/v1",
      "document": {"receipt_kind": "server_transport", "binding_is_separate": true},
      "expected_code": null
    },
    {
      "fixture_id": "receipt_idempotency_exact_binding",
      "fixture_class": "idempotency",
      "schema_id": "server-transport-receipt-binding/v1",
      "document": {"same_receipt_digest": true, "same_transport_envelope_digest": true},
      "expected_code": null
    },
    {
      "fixture_id": "receipt_negative_rebinding",
      "fixture_class": "negative",
      "schema_id": "server-transport-receipt-binding/v1",
      "document": {"existing_transport_envelope_digest": "a", "presented_transport_envelope_digest": "b"},
      "expected_code": "TRANSPORT_RECEIPT_ALREADY_BOUND"
    },
    {
      "fixture_id": "receipt_negative_transport_as_local",
      "fixture_class": "negative",
      "schema_id": "server-transport-receipt/v1",
      "document": {"receipt_kind": "local_tool"},
      "expected_code": "TRANSPORT_RECEIPT_TYPE_INVALID"
    }
  ]
}

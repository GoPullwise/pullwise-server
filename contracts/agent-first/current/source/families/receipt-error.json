{
  "family_id": "receipt-error",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "dispatch-abandonment/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "abandonment_digest",
        "domain": "pullwise:dispatch-abandonment:v1"
      },
      "required": [
        "schema_id",
        "package",
        "intent_id",
        "invocation_digest",
        "reservation_id",
        "reason",
        "budget_settlement_digest",
        "abandoned_at",
        "abandonment_digest"
      ],
      "properties": {
        "schema_id": { "const": "dispatch-abandonment/v1" },
        "package": { "$ref": "current-package-ref/v1" },
        "intent_id": { "type": "string", "pattern": "^intent_[0-9a-f]{32}$" },
        "invocation_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "reservation_id": { "type": "string", "pattern": "^reserve_[0-9a-f]{32}$" },
        "reason": {
          "enum": ["authority_lost", "dispatch_not_started", "worker_shutdown", "recovery_timeout"]
        },
        "budget_settlement_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "abandoned_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9:.]+Z$" },
        "abandonment_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "error-response/v1",
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "error"],
      "properties": {
        "schema_id": { "const": "error-response/v1" },
        "error": { "$ref": "stable-error/v1" }
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "server-transport-receipt-binding-response/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "response_digest",
        "domain": "pullwise:server-transport-receipt-binding-response:v1"
      },
      "required": [
        "schema_id",
        "receipt_id",
        "receipt_digest",
        "transport_envelope_digest",
        "state",
        "bound_at",
        "response_digest"
      ],
      "properties": {
        "schema_id": { "const": "server-transport-receipt-binding-response/v1" },
        "receipt_id": { "type": "string", "pattern": "^receipt_[0-9a-f]{32}$" },
        "receipt_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "transport_envelope_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "state": { "const": "bound" },
        "bound_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9:.]+Z$" },
        "response_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "server-transport-receipt-binding/v1",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_id",
        "receipt_id",
        "receipt_digest",
        "state",
        "bound_transport_envelope_digest"
      ],
      "properties": {
        "schema_id": { "const": "server-transport-receipt-binding/v1" },
        "receipt_id": { "type": "string", "pattern": "^receipt_[0-9a-f]{32}$" },
        "receipt_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "state": { "enum": ["unbound", "bound"] },
        "bound_transport_envelope_digest": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "server-transport-receipt/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "receipt_digest",
        "domain": "pullwise:server-transport-receipt:v1"
      },
      "required": [
        "schema_id",
        "receipt_kind",
        "package",
        "receipt_id",
        "task_id",
        "attempt_id",
        "session_id",
        "owner_id",
        "lease_id",
        "authority_digest",
        "grant_digest",
        "task_version",
        "deletion_version",
        "owner_epoch",
        "native_epoch",
        "transport_epoch",
        "content_ref",
        "accepted_at",
        "receipt_digest"
      ],
      "properties": {
        "schema_id": { "const": "server-transport-receipt/v1" },
        "receipt_kind": { "const": "server_transport" },
        "package": { "$ref": "current-package-ref/v1" },
        "receipt_id": { "type": "string", "pattern": "^receipt_[0-9a-f]{32}$" },
        "task_id": { "type": "string", "pattern": "^task_[0-9a-f]{32}$" },
        "attempt_id": { "type": "string", "pattern": "^attempt_[0-9a-f]{32}$" },
        "session_id": { "type": "string", "pattern": "^sess_[0-9a-f]{32}$" },
        "owner_id": { "type": "string", "pattern": "^owner_[0-9a-f]{32}$" },
        "lease_id": { "type": "string", "pattern": "^lease_[0-9a-f]{32}$" },
        "authority_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "grant_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "task_version": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "deletion_version": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "owner_epoch": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "native_epoch": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "transport_epoch": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
        "content_ref": {
          "$ref": "content-ref/v1",
          "x-pullwise-content-schema-id": "worker-debug-fragment/v1"
        },
        "accepted_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9:.]+Z$" },
        "receipt_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "stable-error-registry/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {
        "field": "registry_digest",
        "domain": "pullwise:stable-error-registry:v1"
      },
      "required": ["schema_id", "entries", "registry_digest"],
      "properties": {
        "schema_id": { "const": "stable-error-registry/v1" },
        "entries": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "retryable", "retry_scope", "outcome"],
            "properties": {
              "code": {
                "enum": [
                  "ABSOLUTE_DEADLINE_EXCEEDED",
                  "AGENT_GRANT_INVALID",
                  "ATTESTATION_NOT_INDEPENDENT",
                  "AUTHORITY_FENCED",
                  "AUTHORITY_INPUT_UNTRUSTED",
                  "AUTHORITY_RELOAD_REQUIRED",
                  "BUDGET_EXHAUSTED",
                  "CAS_CORRUPT",
                  "CONTRACT_DOCUMENT_INVALID",
                  "CURRENT_PACKAGE_PIN_MISMATCH",
                  "CURRENT_PACKAGE_PIN_MISSING",
                  "DEBUG_REDACTION_FAILED",
                  "DEBUG_UPLOAD_FAILED",
                  "DISPATCH_ABANDONED",
                  "EVENT_DELIVERY_UNKNOWN",
                  "EVIDENCE_CLOSURE_INVALID",
                  "EXECUTION_STATE_UNAVAILABLE",
                  "GATE_INPUT_CLOSURE_DIRECTION_INVALID",
                  "GATE_INPUT_STALE",
                  "IDEMPOTENCY_CONFLICT",
                  "INVOCATION_PENDING",
                  "LEASE_INVALID",
                  "MANDATORY_REQUIREMENT_FAILED",
                  "MANDATORY_REQUIREMENT_UNVERIFIABLE",
                  "NATIVE_EPOCH_STALE",
                  "OBSERVATION_ACTOR_MISMATCH",
                  "OBSERVATION_MISSING",
                  "OWNER_EPOCH_STALE",
                  "POLICY_INVARIANT_BROKEN",
                  "POLICY_UNSUPPORTED",
                  "PROTOCOL_FAILURE",
                  "REQUIREMENT_ID_COLLISION",
                  "ROLE_NOT_ENABLED",
                  "SOURCE_STATE_CHANGED",
                  "SOURCE_STATE_MISMATCH",
                  "STATE_TRANSITION_INVALID",
                  "TASK_NOT_CLAIMABLE",
                  "TASK_VERSION_STALE",
                  "TERMINALIZATION_RESERVE_REACHED",
                  "TRANSPORT_BINDING_ROLLED_BACK",
                  "TRANSPORT_ENVELOPE_DIGEST_INVALID",
                  "TRANSPORT_RECEIPT_ALREADY_BOUND",
                  "TRANSPORT_RECEIPT_BINDING_CONFLICT",
                  "TRANSPORT_RECEIPT_TYPE_INVALID",
                  "WAIVER_INVALID"
                ]
              },
              "retryable": { "type": "boolean" },
              "retry_scope": { "enum": ["none", "same_invocation", "new_claim", "operator"] },
              "outcome": { "enum": ["error", "pending", "rejected", "fenced", "conflict"] }
            }
          }
        },
        "registry_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "stable-error/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": { "field": "error_digest", "domain": "pullwise:stable-error:v1" },
      "required": [
        "schema_id",
        "code",
        "message",
        "retryable",
        "retry_scope",
        "request_id",
        "details",
        "error_digest"
      ],
      "properties": {
        "schema_id": { "const": "stable-error/v1" },
        "code": {
          "enum": [
            "ABSOLUTE_DEADLINE_EXCEEDED",
            "AGENT_GRANT_INVALID",
            "ATTESTATION_NOT_INDEPENDENT",
            "AUTHORITY_FENCED",
            "AUTHORITY_INPUT_UNTRUSTED",
            "AUTHORITY_RELOAD_REQUIRED",
            "BUDGET_EXHAUSTED",
            "CAS_CORRUPT",
            "CONTRACT_DOCUMENT_INVALID",
            "CURRENT_PACKAGE_PIN_MISMATCH",
            "CURRENT_PACKAGE_PIN_MISSING",
            "DEBUG_REDACTION_FAILED",
            "DEBUG_UPLOAD_FAILED",
            "DISPATCH_ABANDONED",
            "EVENT_DELIVERY_UNKNOWN",
            "EVIDENCE_CLOSURE_INVALID",
            "EXECUTION_STATE_UNAVAILABLE",
            "GATE_INPUT_CLOSURE_DIRECTION_INVALID",
            "GATE_INPUT_STALE",
            "IDEMPOTENCY_CONFLICT",
            "INVOCATION_PENDING",
            "LEASE_INVALID",
            "MANDATORY_REQUIREMENT_FAILED",
            "MANDATORY_REQUIREMENT_UNVERIFIABLE",
            "NATIVE_EPOCH_STALE",
            "OBSERVATION_ACTOR_MISMATCH",
            "OBSERVATION_MISSING",
            "OWNER_EPOCH_STALE",
            "POLICY_INVARIANT_BROKEN",
            "POLICY_UNSUPPORTED",
            "PROTOCOL_FAILURE",
            "REQUIREMENT_ID_COLLISION",
            "ROLE_NOT_ENABLED",
            "SOURCE_STATE_CHANGED",
            "SOURCE_STATE_MISMATCH",
            "STATE_TRANSITION_INVALID",
            "TASK_NOT_CLAIMABLE",
            "TASK_VERSION_STALE",
            "TERMINALIZATION_RESERVE_REACHED",
            "TRANSPORT_BINDING_ROLLED_BACK",
            "TRANSPORT_ENVELOPE_DIGEST_INVALID",
            "TRANSPORT_RECEIPT_ALREADY_BOUND",
            "TRANSPORT_RECEIPT_BINDING_CONFLICT",
            "TRANSPORT_RECEIPT_TYPE_INVALID",
            "WAIVER_INVALID"
          ]
        },
        "message": { "type": "string", "minLength": 1, "maxLength": 512 },
        "retryable": { "type": "boolean" },
        "retry_scope": { "enum": ["none", "same_invocation", "new_claim", "operator"] },
        "request_id": { "type": "string", "pattern": "^req_[0-9a-f]{32}$" },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "task_id": { "type": "string", "pattern": "^task_[0-9a-f]{32}$" },
            "attempt_id": { "type": "string", "pattern": "^attempt_[0-9a-f]{32}$" },
            "invocation_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "expected_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "actual_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "stable_reason": { "type": "string", "minLength": 1, "maxLength": 160 }
          }
        },
        "error_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  ],

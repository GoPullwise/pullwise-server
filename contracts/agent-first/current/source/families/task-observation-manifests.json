                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "source_state_after_id": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "execution_state_id": {
                "type": [
                  "string",

{
  "family_id": "task-completion-proposal",
  "schemas": [
    {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "completion-proposal/v1",
      "type": "object",
      "additionalProperties": false,
      "x-pullwise-digest": {"field":"proposal_digest","domain":"pullwise:completion-proposal:v1"},
      "x-pullwise-semantics": {
        "document_rules": ["completion_proposal"],
        "contextual_helpers": ["verify_completion_proposal_context"]
      },
      "required": [
        "schema_id",
        "proposal_id",
        "task_id",
        "attempt_id",
        "native_epoch",
        "owner_id",
        "owner_epoch",
        "proposed_from_task_version",
        "outcome_requested",
        "request_digest",
        "requirement_ledger_digest",
        "policy_digest",
        "charter_digest",
        "original_source_state_id",
        "final_source_state_id",
        "execution_state_ids",
        "change_set_ref",
        "artifact_refs",
        "requirement_claims",
        "known_gaps",
        "residual_risks",
        "created_at",
        "proposal_digest"
      ],
      "properties": {
        "schema_id": {"const":"completion-proposal/v1"},
        "proposal_id": {"type":"string","pattern":"^proposal_[0-9a-f]{32}$"},
        "task_id": {"type":"string","pattern":"^task_[0-9a-f]{32}$"},
        "attempt_id": {"type":"string","pattern":"^attempt_[0-9a-f]{32}$"},
        "native_epoch": {"type":"integer","minimum":1,"maximum":9007199254740991},
        "owner_id": {"type":"string","pattern":"^owner_[0-9a-f]{32}$"},
        "owner_epoch": {"type":"integer","minimum":1,"maximum":9007199254740991},
        "proposed_from_task_version": {"type":"integer","minimum":1,"maximum":9007199254740990},
        "outcome_requested": {"enum":["COMPLETED","COMPLETED_WITH_WAIVERS","NO_CHANGE_NEEDED","PARTIAL"]},
        "request_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "requirement_ledger_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "policy_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "charter_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "original_source_state_id": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "final_source_state_id": {"type":"string","pattern":"^[0-9a-f]{64}$"},
        "execution_state_ids": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": {"type":"string","pattern":"^[0-9a-f]{64}$"}
        },
        "change_set_ref": {
          "oneOf": [{"$ref":"content-ref/v1","x-pullwise-content-schema-id":"change-set/v1"},{"type":"null"}]
        },
        "artifact_refs": {
          "type": "array",
          "maxItems": 4096,
          "uniqueItems": true,
          "items": {"$ref":"artifact-content-ref/v1"}
        },
        "requirement_claims": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["requirement_id","claimed_status","evidence_ids"],
            "properties": {
              "requirement_id": {
                "type": "string",
                "pattern": "^req_(?:user_objective|user_acceptance|user_constraint|delivery|policy|interaction|derived)_[0-9a-f]{64}$"
              },
              "claimed_status": {"enum":["NEEDS_WORK","PASS","POLICY_VIOLATION","UNVERIFIABLE"]},
              "evidence_ids": {
                "type": "array",
                "maxItems": 256,
                "uniqueItems": true,
                "items": {"type":"string","pattern":"^obs_[0-9a-f]{32}$"}
              }
            }
          }
        },
        "known_gaps": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": {"type":"string","minLength":1,"maxLength":4096}
        },
        "residual_risks": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": {"type":"string","minLength":1,"maxLength":4096}
        },
        "created_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "proposal_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"}
      }
    }
  ],

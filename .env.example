# Server bind address
PULLWISE_HOST=0.0.0.0
PULLWISE_PORT=3000

# Browser origins allowed to call the API with credentials. Use exact origins;
# wildcard "*" is intentionally ignored for credentialed requests.
PULLWISE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Public API base URL used when the server creates local callback links.
PULLWISE_API_BASE_URL=http://localhost:3000

# Set true only behind a trusted reverse proxy such as the included Cloudflare
# Pages Function. Used when PULLWISE_API_BASE_URL is not explicitly set.
PULLWISE_TRUST_PROXY_HEADERS=false

# Default frontend URL used when no redirectTo is supplied.
PULLWISE_APP_URL=http://localhost:5173

# Optional override. By default cookies are Secure when the public API or app URL
# starts with https:// and not Secure for local http:// development.
PULLWISE_COOKIE_SECURE=

# Local persistent storage. Defaults to .pullwise/pullwise.sqlite3.
PULLWISE_DB_PATH=

# Daily dated log files. Defaults to .pullwise/logs/pullwise-YYYY-MM-DD.log.
# PULLWISE_LOG_ROTATION_TIME is local server time in HH:MM format.
PULLWISE_LOG_DIR=
PULLWISE_LOG_LEVEL=INFO
PULLWISE_LOG_ROTATION_TIME=00:00

# Local mock identity shown for GitHub sign-in.
PULLWISE_DEV_GITHUB_LOGIN=taylor-dev
PULLWISE_DEV_EMAIL=taylor@acme.io

# Real GitHub identity login. When both values are set,
# /auth/github/authorize redirects to GitHub OAuth instead of the local mock.
PULLWISE_GITHUB_CLIENT_ID=
PULLWISE_GITHUB_CLIENT_SECRET=
PULLWISE_GITHUB_OAUTH_SCOPE=read:user user:email

# Real email magic links. Configure SMTP to enable /auth/email/magic-link
# without returning local development links in API responses.
PULLWISE_EMAIL_PROVIDER=
PULLWISE_EMAIL_FROM=
PULLWISE_SMTP_HOST=
PULLWISE_SMTP_PORT=587
PULLWISE_SMTP_USERNAME=
PULLWISE_SMTP_PASSWORD=
PULLWISE_SMTP_STARTTLS=true

# Billing. Set exactly one provider's credentials, or set
# PULLWISE_BILLING_PROVIDER=stripe|creem when both are present.
PULLWISE_BILLING_PROVIDER=
PULLWISE_BILLING_PLAN_NAME=Pullwise Pro
PULLWISE_BILLING_PLAN_DESCRIPTION=Repository review for production teams.
PULLWISE_BILLING_AMOUNT=
PULLWISE_BILLING_CURRENCY=USD
PULLWISE_BILLING_INTERVAL=month
PULLWISE_STRIPE_SECRET_KEY=
PULLWISE_STRIPE_PRICE_ID=
PULLWISE_STRIPE_WEBHOOK_SECRET=
PULLWISE_CREEM_API_KEY=
PULLWISE_CREEM_PRODUCT_ID=
PULLWISE_CREEM_WEBHOOK_SECRET=
PULLWISE_CREEM_TEST_MODE=false
# Optional override, e.g. https://test-api.creem.io
PULLWISE_CREEM_API_BASE_URL=

# Real GitHub repository authorization through a GitHub App installation.
# The GitHub App must be Public / Any account so users can install it on their
# own personal account or organization. Private apps are owner-account only.
# Repository Contents permission must be read-only. Do not grant write access.
# The app setup URL in GitHub should point to:
# http://localhost:3000/integrations/github/callback
PULLWISE_GITHUB_APP_SLUG=
PULLWISE_GITHUB_APP_ID=
PULLWISE_GITHUB_APP_PRIVATE_KEY_PATH=
# Keep enabled to fail fast when the configured app slug is private or wrong.
# Do not disable for real user repository installs.
PULLWISE_GITHUB_APP_VISIBILITY_CHECK=true
# Optional custom install URL still requires PULLWISE_GITHUB_APP_SLUG above so
# the backend can verify the app is public before opening GitHub.
# PULLWISE_GITHUB_APP_INSTALL_URL=
# Alternative to PATH when deploying through env-only secret stores:
# PULLWISE_GITHUB_APP_PRIVATE_KEY_BASE64=

# Optional, mainly for GitHub Enterprise Server.
# PULLWISE_GITHUB_WEB_URL=https://github.com
# PULLWISE_GITHUB_API_URL=https://api.github.com

# Code review provider. disabled refuses scans until a real provider is set.
# CLI providers use their own login state; run `codex login` or `claude login`
# as the same OS user/session that runs Pullwise. They also require a real
# GitHub App installation token so the worker can clone. Use mock only for
# explicit local frontend wire-up.
PULLWISE_REVIEW_PROVIDER=disabled
PULLWISE_REVIEW_TIMEOUT_SECONDS=600
# Single-machine resource guard for Git clone + Codex/Claude CLI work.
# These cap running scans. Extra scans are accepted as queued work and expose
# queue.position / queue.ahead in the API until a worker can start them.
PULLWISE_MAX_CONCURRENT_SCANS=1
PULLWISE_MAX_CONCURRENT_SCANS_PER_USER=1
PULLWISE_CHECKOUT_ROOT=
PULLWISE_GIT_CLONE_DEPTH=1

# Pullwise server environment
# Copy this file to .env for local runs, or to /etc/pullwise/server.env for
# Ubuntu/systemd production. Replace example domains and paths before deploy.

# ---- REQUIRED: production HTTP/runtime ----
PULLWISE_MODE=production
PULLWISE_HOST=0.0.0.0
PULLWISE_PORT=8080
PULLWISE_APP_URL=https://app.your-domain.com
PULLWISE_ALLOWED_ORIGINS=https://app.your-domain.com,https://admin.your-domain.com
PULLWISE_API_BASE_URL=https://app.your-domain.com/api
PULLWISE_COOKIE_SECURE=true
PULLWISE_COOKIE_SAME_SITE=Lax

# ---- OPTIONAL: proxy-derived API base ----
# Use this only behind a trusted proxy that sets X-Forwarded-Proto,
# X-Forwarded-Host, and X-Forwarded-Prefix. If this is true,
# PULLWISE_API_BASE_URL may be omitted.
PULLWISE_TRUST_PROXY_HEADERS=false

# ---- REQUIRED: production storage ----
# Defaults exist for local development, but production should use persistent
# writable paths outside the project tree.
PULLWISE_DB_PATH=/var/lib/pullwise/pullwise.sqlite3
PULLWISE_LOG_DIR=/var/log/pullwise
PULLWISE_CHECKOUT_ROOT=/var/lib/pullwise/checkouts

# ---- OPTIONAL: logs and request limits ----
PULLWISE_LOG_LEVEL=INFO
PULLWISE_LOG_ROTATION_TIME=00:00
PULLWISE_MAX_BODY_BYTES=1048576
PULLWISE_RATE_LIMIT_ENABLED=true
PULLWISE_RATE_LIMIT_REQUESTS=600
PULLWISE_RATE_LIMIT_WINDOW_SECONDS=60

# ---- REQUIRED: real GitHub sign-in ----
PULLWISE_GITHUB_CLIENT_ID=your_oauth_or_github_app_client_id
PULLWISE_GITHUB_CLIENT_SECRET=your_oauth_or_github_app_client_secret

# ---- OPTIONAL: GitHub OAuth behavior ----
PULLWISE_GITHUB_OAUTH_SCOPE=read:user user:email
# PULLWISE_GITHUB_OAUTH_PROMPT=
# PULLWISE_GITHUB_ALLOW_SIGNUP=

# ---- REQUIRED: GitHub App repository access ----
# GitHub App requirements:
# - Public / Any account
# - Contents permission: read-only
# - Callback URL: https://app.your-domain.com/api/auth/github/callback
# - Setup URL: https://app.your-domain.com/api/integrations/github/callback
PULLWISE_GITHUB_APP_SLUG=your-github-app-slug
PULLWISE_GITHUB_APP_ID=123456

# Choose exactly one private-key source.
PULLWISE_GITHUB_APP_PRIVATE_KEY_PATH=/etc/pullwise/secrets/github-app-private-key.pem
# PULLWISE_GITHUB_APP_PRIVATE_KEY_BASE64=

# ---- OPTIONAL: GitHub App safety and GitHub Enterprise ----
PULLWISE_GITHUB_APP_VISIBILITY_CHECK=true
# PULLWISE_GITHUB_APP_INSTALL_URL=
# PULLWISE_GITHUB_WEB_URL=https://github.com
# PULLWISE_GITHUB_API_URL=https://api.github.com
# PULLWISE_GITHUB_API_VERSION=2022-11-28
# PULLWISE_GITHUB_TIMEOUT_SECONDS=12

# ---- OPTIONAL: external worker queue tuning ----
PULLWISE_MAX_CONCURRENT_SCANS=1
PULLWISE_MAX_CONCURRENT_SCANS_PER_USER=1
PULLWISE_GIT_CLONE_DEPTH=1

# ---- OPTIONAL: operational cleanup ----
# Does not delete user-visible scan results in SCANS/ISSUES.
PULLWISE_SERVER_CLEANUP_INTERVAL_SECONDS=3600
PULLWISE_SCAN_JOB_RETENTION_SECONDS=2592000
PULLWISE_WORKER_COMMAND_RETENTION_SECONDS=2592000
PULLWISE_WORKER_AUDIT_RETENTION_SECONDS=7776000

# ---- OPTIONAL: billing ----
# Leave blank to disable billing. Configure Stripe or Creem only if billing is
# part of this deployment. If both providers are configured, set
# PULLWISE_BILLING_PROVIDER=stripe or creem.
PULLWISE_BILLING_PROVIDER=
PULLWISE_BILLING_PLAN_NAME=Pullwise Pro
PULLWISE_BILLING_PLAN_DESCRIPTION=Shared workspace and repository review quota for production teams.
PULLWISE_BILLING_CURRENCY=USD
PULLWISE_FREE_WORKSPACE_REVIEW_LIMIT=10
PULLWISE_FREE_REPO_REVIEW_LIMIT=3
PULLWISE_PRO_WORKSPACE_REVIEW_LIMIT=100
# Legacy compatibility aliases. Prefer the workspace/repository variables above.
# PULLWISE_FREE_REVIEW_LIMIT=10
# PULLWISE_PRO_REVIEW_LIMIT=100
PULLWISE_PRO_MONTHLY_AMOUNT=29
PULLWISE_PRO_YEARLY_AMOUNT=290

# Stripe billing, optional.
# Required for Stripe billing: secret key, monthly price, yearly price,
# and webhook secret. Prices must be recurring subscription prices in USD.
PULLWISE_STRIPE_SECRET_KEY=
PULLWISE_STRIPE_PRO_MONTHLY_PRICE_ID=
PULLWISE_STRIPE_PRO_YEARLY_PRICE_ID=
PULLWISE_STRIPE_WEBHOOK_SECRET=
PULLWISE_STRIPE_CHECKOUT_MODE=subscription

# Creem billing, optional.
# Required for Creem billing: API key, monthly product, yearly product,
# and webhook secret. Products must be recurring subscription products in USD.
PULLWISE_CREEM_API_KEY=
PULLWISE_CREEM_PRO_MONTHLY_PRODUCT_ID=
PULLWISE_CREEM_PRO_YEARLY_PRODUCT_ID=
PULLWISE_CREEM_WEBHOOK_SECRET=
PULLWISE_CREEM_TEST_MODE=false
PULLWISE_CREEM_UPGRADE_BEHAVIOR=proration-charge-immediately
# PULLWISE_CREEM_API_BASE_URL=

# ---- OPTIONAL: local development only ----
# These are ignored once real GitHub OAuth is configured.
PULLWISE_DEV_GITHUB_LOGIN=taylor-dev
PULLWISE_DEV_EMAIL=taylor@acme.io
